---
const year = new Date().getFullYear();
---

<footer style="background:#1F2925; padding:70px 0 30px;">
  <div style="max-width:1280px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
    <div style="display:flex; flex-wrap:wrap; gap:48px; padding-bottom:48px; border-bottom:1px solid rgba(255,255,255,0.1);">
      <div style="flex:2 1 280px; min-width:240px;">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
          <img src="/logo.png" alt="Logo ANB Bordeaux" width="44" height="44" style="width:44px; height:44px; border-radius:50%; object-fit:cover;" />
          <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:16px; color:#FFFFFF;">ANB Bordeaux</span>
        </div>
        <p style="font-size:15px; line-height:1.65; color:rgba(248,244,236,0.7); max-width:320px; margin:0;">Ensemble, faire vivre la communauté nigérienne à Bordeaux.</p>
      </div>
      <div style="flex:1 1 160px; min-width:150px;">
        <div style="font-size:13px; font-weight:700; color:#E97824; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:18px;">Liens rapides</div>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <a href="/association" style="color:rgba(248,244,236,0.75); font-size:14.5px; cursor:pointer;">L'association</a>
          <a href="/evenements" style="color:rgba(248,244,236,0.75); font-size:14.5px; cursor:pointer;">Événements</a>
          <a href="/galerie" style="color:rgba(248,244,236,0.75); font-size:14.5px; cursor:pointer;">Galerie</a>
          <a href="/adherer" style="color:rgba(248,244,236,0.75); font-size:14.5px; cursor:pointer;">Adhérer / Nous soutenir</a>
        </div>
      </div>
      <div style="flex:1 1 160px; min-width:150px;">
        <div style="font-size:13px; font-weight:700; color:#E97824; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:18px;">Contact</div>
        <div style="display:flex; flex-direction:column; gap:12px; color:rgba(248,244,236,0.75); font-size:14.5px;">
          <div>Bordeaux Métropole</div>
          <div>contact@anb-bordeaux.fr</div>
          <div>06 00 00 00 00</div>
        </div>
      </div>
      <div style="flex:1 1 160px; min-width:150px;">
        <div style="font-size:13px; font-weight:700; color:#E97824; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:18px;">Suivez-nous</div>
        <div style="display:flex; gap:12px;">
          <div style="width:38px; height:38px; border-radius:10px; background:rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#F8F4EC"><path d="M14 8.5h2.5V5.2C16 5.2 14.8 5 13.5 5 10.7 5 9 6.7 9 9.7v2.3H6v3.7h3V22h3.7v-6.3h3l0.5-3.7h-3.5V10c0-1 .3-1.5 1.3-1.5z"></path></svg>
          </div>
          <div style="width:38px; height:38px; border-radius:10px; background:rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F8F4EC" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="3.8"></circle><circle cx="17.2" cy="6.8" r="1"></circle></svg>
          </div>
          <div style="width:38px; height:38px; border-radius:10px; background:rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#F8F4EC"><path d="M12 2a10 10 0 00-8.5 15.2L2 22l4.9-1.4A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1112 20zm4.4-5.9c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1-.7-.3-1.4-.7-2-1.3-.5-.5-1-1.1-1.4-1.7-.1-.2 0-.4.1-.5l.4-.5c.1-.2.2-.3.1-.5-.1-.2-.5-1.3-.7-1.7-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.6.3-.7.7-1 1.5-1 2.4.1 1 .5 2 1.2 2.9 1.2 1.7 2.7 3 4.6 3.7.6.2 1.1.4 1.7.5.7.1 1.3.1 1.9-.1.6-.2 1.4-.9 1.6-1.5.2-.6.2-1.1.1-1.2-.1-.1-.2-.1-.4-.2z"></path></svg>
          </div>
          <div style="width:38px; height:38px; border-radius:10px; background:rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#F8F4EC"><path d="M4 3.5h4.2v17H4v-17zm2.1 0a2.4 2.4 0 110 4.8 2.4 2.4 0 010-4.8zM10.6 8.5h4v2c0.6-1.1 2-2.3 4.1-2.3 4.4 0 5.2 2.7 5.2 6.3v8h-4.2v-7.1c0-1.7 0-3.9-2.4-3.9-2.4 0-2.8 1.9-2.8 3.8v7.2h-4.2v-14z"></path></svg>
          </div>
        </div>
      </div>
    </div>
    <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:space-between; padding-top:26px;">
      <div style="font-size:13px; color:rgba(248,244,236,0.5);">© {year} ANB — Association des Nigériens à Bordeaux</div>
      <div style="display:flex; gap:20px; flex-wrap:wrap;">
        <a href="/mentions-legales" style="font-size:13px; color:rgba(248,244,236,0.5); cursor:pointer;">Mentions légales</a>
        <a href="/cgu" style="font-size:13px; color:rgba(248,244,236,0.5); cursor:pointer;">CGU</a>
        <a href="/confidentialite" style="font-size:13px; color:rgba(248,244,236,0.5); cursor:pointer;">Politique de confidentialité</a>
        <a href="/connexion" style="font-size:13px; color:rgba(248,244,236,0.5); cursor:pointer;">Espace ANB</a>
      </div>
    </div>
  </div>
</footer>
