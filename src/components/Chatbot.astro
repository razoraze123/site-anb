---
// Chatbot component calling our secure backend proxy endpoint
---

<div id="anb-chatbot-wrapper" style="position: fixed; bottom: 24px; right: 24px; z-index: 9999; font-family: 'Manrope', sans-serif;">
  
  <!-- FLOATING CHAT BUTTON -->
  <button id="anb-chat-trigger" aria-label="Ouvrir l'assistant virtuel" style="width: 60px; height: 60px; border-radius: 50%; background: linear-gradient(135deg, #E97824, #176B4D); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(233, 120, 36, 0.35); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s; position: relative;">
    <!-- Chat Icon -->
    <svg id="chat-icon-svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.3s;">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <!-- Close Icon (Hidden by default) -->
    <svg id="close-icon-svg" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position: absolute; transition: transform 0.3s; transform: scale(0);">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
    <!-- Notification badge -->
    <span id="chat-badge" style="position: absolute; top: -2px; right: -2px; width: 12px; height: 12px; border-radius: 50%; background: #B14524; border: 2px solid #FFFFFF; transform: scale(1); transition: transform 0.3s;"></span>
  </button>

  <!-- CHAT WINDOW -->
  <div id="anb-chat-window" class="hidden" style="width: 380px; height: 520px; max-height: calc(100vh - 110px); max-width: calc(100vw - 48px); background: #FFFFFF; border-radius: 24px; box-shadow: 0 12px 40px rgba(31, 41, 37, 0.16); display: flex; flex-direction: column; overflow: hidden; position: absolute; bottom: 76px; right: 0; transform: translateY(20px); opacity: 0; pointer-events: none; transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s;">
    
    <!-- HEADER -->
    <div style="background: #176B4D; padding: 18px 20px; display: flex; align-items: center; gap: 12px; color: #FFFFFF; border-bottom: 1px solid rgba(255,255,255,0.08);">
      <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: 'Unbounded', sans-serif; font-weight: 700; font-size: 13px; color: #FFFFFF;">
        ANB
      </div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-weight: 700; font-size: 15px; letter-spacing: -0.01em;">Assistant ANB</div>
        <div style="display: flex; align-items: center; gap: 6px; font-size: 11px; opacity: 0.85; margin-top: 1px;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: #51CF66; display: inline-block;"></span>
          En ligne
        </div>
      </div>
      <button id="anb-chat-close-btn" aria-label="Fermer le chat" style="background: rgba(255,255,255,0.1); border: none; width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #FFFFFF; transition: background 0.2s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- MESSAGES LIST -->
    <div id="anb-chat-messages" style="flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 14px; background: #FAF7F2;">
      <!-- Welcome message -->
      <div class="bot-msg-wrapper" style="display: flex; flex-direction: column; gap: 4px; max-width: 82%;">
        <div style="background: #FFFFFF; border: 1.5px solid #EDE6D6; border-radius: 16px 16px 16px 4px; padding: 12px 14px; font-size: 14px; line-height: 1.5; color: #1F2925;">
          Bonjour ! Je suis l'assistant virtuel de l'ANB. Comment puis-je vous aider aujourd'hui ? Vous pouvez me poser des questions sur nos événements, les adhésions ou l'accompagnement étudiant. 🇳🇪
        </div>
        <span style="font-size: 10.5px; color: #9aa39c; margin-left: 6px;">Assistant ANB</span>
      </div>
    </div>

    <!-- INPUT AREA -->
    <div style="padding: 14px 16px; background: #FFFFFF; border-top: 1.5px solid #EDE6D6; display: flex; align-items: center; gap: 10px;">
      <input id="anb-chat-input" placeholder="Écrivez votre message..." style="flex: 1; border: 1.5px solid #EDE6D6; padding: 12px 16px; border-radius: 999px; font-size: 13.5px; outline: none; transition: border-color 0.2s;" />
      <button id="anb-chat-send" aria-label="Envoyer le message" style="width: 42px; height: 42px; border-radius: 50%; background: #E97824; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #FFFFFF; transition: background 0.2s, transform 0.1s;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>

  </div>

</div>

<style>
  .hidden { display: none !important; }
  .anb-chat-window-active {
    transform: translateY(0) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }
  .role-pulse {
    box-shadow: 0 0 0 0 rgba(233, 120, 36, 0.7);
    animation: anb-pulse 2s infinite;
  }
  @keyframes anb-pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(233, 120, 36, 0.5); }
    70% { transform: scale(1.03); box-shadow: 0 0 0 10px rgba(233, 120, 36, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(233, 120, 36, 0); }
  }
  
  /* Typing Indicator Bouncing Dots */
  .bouncing-loader {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    padding: 4px 6px;
  }
  .bouncing-loader > div {
    width: 6px;
    height: 6px;
    background: #176B4D;
    border-radius: 50%;
    animation: bouncing-loader 0.6s infinite alternate;
  }
  .bouncing-loader > div:nth-child(2) { animation-delay: 0.2s; }
  .bouncing-loader > div:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bouncing-loader {
    to { opacity: 0.1; transform: translateY(-4px); }
  }
</style>

<script is:inline>
  const trigger = document.getElementById('anb-chat-trigger');
  const windowEl = document.getElementById('anb-chat-window');
  const closeBtn = document.getElementById('anb-chat-close-btn');
  const inputEl = document.getElementById('anb-chat-input');
  const sendBtn = document.getElementById('anb-chat-send');
  const messagesEl = document.getElementById('anb-chat-messages');
  const badgeEl = document.getElementById('chat-badge');
  const chatIcon = document.getElementById('chat-icon-svg');
  const closeIcon = document.getElementById('close-icon-svg');

  let chatHistory = [];
  let isWindowOpen = false;

  // System instructions context
  const systemPrompt = {
    role: "system",
    content: "Tu es l'assistant virtuel officiel de l'Association des Nigériens à Bordeaux (ANB). Ton rôle est d'informer chaleureusement les visiteurs sur les activités et les services de l'association.\n\nCONSIGNE STRICTE ET ABSOLUE : Tu ne dois répondre QU'AUX questions en rapport direct avec l'ANB, ses événements, ses membres, l'entraide communautaire, ou la culture nigérienne. Si l'utilisateur pose une question hors-sujet (par exemple : apprendre Python, faire une recette générale de cuisine, de l'aide pour les devoirs, etc.), tu dois REFUSER POLIMENT de répondre et lui rappeler ton rôle d'assistant de l'ANB Bordeaux en le réorientant vers nos rubriques comme l'adhésion, les événements ou le contact.\n\nVoici les informations clés sur l'ANB :\n- Mission : Rassembler, accompagner (notamment les étudiants nigériens arrivant à Bordeaux) et valoriser la culture nigérienne.\n- Événements à venir en 2026 :\n  1. Journée culturelle nigérienne : Samedi 20 septembre 2026 au Parc Bordelais (11h00), avec repas traditionnel, danses et stands de présentation.\n  2. Tournoi de football amical : Dimanche 12 octobre 2026 au Stade Léo Lagrange.\n  3. Soirée d'entraide et collecte solidaire : Samedi 8 novembre 2026 en salle associative.\n- Pages utiles du site :\n  - Adhésion (/adherer) : pour cotiser et devenir membre actif.\n  - Contact (/contact) : formulaire et e-mail de contact (contact@anb-bordeaux.fr).\n  - Culture (/culture-nigerienne) : découvrir les traditions et la gastronomie du Niger.\n  - Vie Pratique (/vie-pratique) : ressources pour le logement, les études et les démarches administratives.\n- Équipe dirigeante : Nasser Diallo (Super Admin/Présidence), Mariama Souley (Admin/Animation du site).\n\nSois poli, concis (maximum 2 phrases par réponse), chaleureux, et réponds toujours en français. N'invente pas d'informations non mentionnées. Propose des liens vers les pages du site sous format textuel simple (ex : vous pouvez visiter /adherer)."
  };

  // Add system prompt to history
  chatHistory.push(systemPrompt);

  // Load chat from session storage if exists
  if (sessionStorage.getItem('anb_chat_history')) {
    try {
      const saved = JSON.parse(sessionStorage.getItem('anb_chat_history'));
      if (Array.isArray(saved) && saved.length > 1) {
        chatHistory = saved;
        // Re-render chat UI
        chatHistory.slice(1).forEach(msg => {
          appendMessageUI(msg.role === 'user' ? 'user' : 'bot', msg.content);
        });
        badgeEl.style.transform = 'scale(0)';
      }
    } catch(e) {
      console.error(e);
    }
  }

  // Toggle chat window
  trigger.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', toggleChat);

  function toggleChat() {
    isWindowOpen = !isWindowOpen;
    if (isWindowOpen) {
      windowEl.classList.remove('hidden');
      setTimeout(() => {
        windowEl.classList.add('anb-chat-window-active');
      }, 10);
      badgeEl.style.transform = 'scale(0)';
      // Rotate icons
      chatIcon.style.transform = 'scale(0) rotate(180deg)';
      chatIcon.classList.add('hidden');
      closeIcon.style.transform = 'scale(1) rotate(180deg)';
      closeIcon.classList.remove('hidden');
      inputEl.focus();
      scrollToBottom();
    } else {
      windowEl.classList.remove('anb-chat-window-active');
      setTimeout(() => {
        windowEl.classList.add('hidden');
      }, 300);
      chatIcon.style.transform = 'scale(1) rotate(0deg)';
      chatIcon.classList.remove('hidden');
      closeIcon.style.transform = 'scale(0) rotate(0deg)';
      closeIcon.classList.add('hidden');
    }
  }

  // Handle send message
  sendBtn.addEventListener('click', handleSendMessage);
  inputEl.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleSendMessage();
  });

  async function handleSendMessage() {
    const text = inputEl.value.trim();
    if (!text) return;

    // Disable input and button
    inputEl.value = '';
    inputEl.disabled = true;
    sendBtn.disabled = true;

    // Append user message UI
    appendMessageUI('user', text);
    chatHistory.push({ role: 'user', content: text });
    sessionStorage.setItem('anb_chat_history', JSON.stringify(chatHistory));

    // Append bot typing indicator
    const loader = appendTypingIndicator();
    scrollToBottom();

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          messages: chatHistory
        })
      });

      if (!response.ok) {
        throw new Error('Erreur de communication avec Mistral AI');
      }

      const data = await response.json();
      const reply = data.choices[0].message.content;

      // Remove loader
      loader.remove();

      // Append bot response UI
      appendMessageUI('bot', reply);
      chatHistory.push({ role: 'assistant', content: reply });
      sessionStorage.setItem('anb_chat_history', JSON.stringify(chatHistory));
    } catch (err) {
      console.error(err);
      loader.remove();
      appendMessageUI('bot', "Désolé, j'ai rencontré un problème pour me connecter à mon serveur. Veuillez réessayer dans quelques instants.");
    } finally {
      inputEl.disabled = false;
      sendBtn.disabled = false;
      inputEl.focus();
      scrollToBottom();
    }
  }

  function appendMessageUI(sender, content) {
    const wrapper = document.createElement('div');
    wrapper.style.display = 'flex';
    wrapper.style.flexDirection = 'column';
    wrapper.style.gap = '4px';
    wrapper.style.maxWidth = '82%';

    if (sender === 'user') {
      wrapper.style.alignSelf = 'flex-end';
      wrapper.innerHTML = `
        <div style="background: #E97824; color: #FFFFFF; border-radius: 16px 16px 4px 16px; padding: 12px 14px; font-size: 14px; line-height: 1.5;">
          ${escapeHtml(content)}
        </div>
        <span style="font-size: 10.5px; color: #9aa39c; align-self: flex-end; margin-right: 6px;">Vous</span>
      `;
    } else {
      wrapper.style.alignSelf = 'flex-start';
      wrapper.innerHTML = `
        <div style="background: #FFFFFF; border: 1.5px solid #EDE6D6; border-radius: 16px 16px 16px 4px; padding: 12px 14px; font-size: 14px; line-height: 1.5; color: #1F2925;">
          ${formatBotReply(content)}
        </div>
        <span style="font-size: 10.5px; color: #9aa39c; margin-left: 6px;">Assistant ANB</span>
      `;
    }

    messagesEl.appendChild(wrapper);
  }

  function appendTypingIndicator() {
    const wrapper = document.createElement('div');
    wrapper.style.display = 'flex';
    wrapper.style.flexDirection = 'column';
    wrapper.style.gap = '4px';
    wrapper.style.maxWidth = '82%';
    wrapper.style.alignSelf = 'flex-start';
    wrapper.innerHTML = `
      <div style="background: #FFFFFF; border: 1.5px solid #EDE6D6; border-radius: 16px 16px 16px 4px; padding: 12px 14px;">
        <div class="bouncing-loader">
          <div></div><div></div><div></div>
        </div>
      </div>
      <span style="font-size: 10.5px; color: #9aa39c; margin-left: 6px;">Assistant ANB écrit...</span>
    `;
    messagesEl.appendChild(wrapper);
    return wrapper;
  }

  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function escapeHtml(text) {
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    };
    return text.replace(/[&<>"']/g, function(m) { return map[m]; });
  }

  function formatBotReply(text) {
    // Transform absolute page links like /adherer, /contact into actual HTML links
    let formatted = escapeHtml(text);
    const routes = ['/adherer', '/contact', '/culture-nigerienne', '/vie-pratique', '/association', '/evenements', '/actualites'];
    routes.forEach(route => {
      const regex = new RegExp(route, 'g');
      formatted = formatted.replace(regex, `<a href="${route}" style="color: #176B4D; font-weight: 700; text-decoration: underline;">${route}</a>`);
    });
    return formatted;
  }

  // Subtle alert pulse to draw attention if no storage is set
  if (!sessionStorage.getItem('anb_chat_history')) {
    setTimeout(() => {
      trigger.classList.add('role-pulse');
    }, 2000);
    // Remove pulse on hover or click
    trigger.addEventListener('mouseenter', () => {
      trigger.classList.remove('role-pulse');
    }, { once: true });
  } else {
    badgeEl.style.transform = 'scale(0)';
  }
</script>
