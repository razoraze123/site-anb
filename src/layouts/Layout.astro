---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "L'ANB rassemble, accompagne et valorise les Nigériens et les amis du Niger à Bordeaux.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} — ANB Bordeaux</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div style="width:100%; min-height:100vh; background:#F8F4EC; color:#1F2925; overflow-x:hidden; position:relative;">
      <Header />
      <slot />
      <Footer />
    </div>
    <script>
      // Drives the orange "shelf-thread" progress bar under each mobile
      // horizontal scroll shelf. A thread is any `.shelf-thread` element
      // immediately following a `.mobile-shelf` in the markup.
      function initShelfThreads() {
        document.querySelectorAll<HTMLElement>('.mobile-shelf').forEach((shelf) => {
          const thread = shelf.nextElementSibling as HTMLElement | null;
          if (!thread?.classList.contains('shelf-thread')) return;
          const thumb = thread.querySelector<HTMLElement>('span');
          if (!thumb) return;

          const update = () => {
            const trackWidth = thread.clientWidth;
            const visibleRatio = Math.min(1, shelf.clientWidth / shelf.scrollWidth);
            const thumbWidth = visibleRatio * trackWidth;
            const maxScroll = shelf.scrollWidth - shelf.clientWidth;
            const scrollRatio = maxScroll > 0 ? shelf.scrollLeft / maxScroll : 0;
            thumb.style.width = `${thumbWidth}px`;
            thumb.style.transform = `translateX(${scrollRatio * (trackWidth - thumbWidth)}px)`;
          };

          shelf.addEventListener('scroll', update, { passive: true });
          window.addEventListener('resize', update);
          update();
        });
      }
      document.addEventListener('DOMContentLoaded', initShelfThreads);
    </script>
  </body>
</html>
