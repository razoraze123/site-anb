<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Espace ANB — Éditeur</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --color-cream: #F8F4EC;
      --color-green: #176B4D;
      --color-orange: #E97824;
      --color-dark: #1F2925;
      --color-sand: #E8D8BF;
      --color-body-text: #3f4a45;
      --color-muted-text: #5a655f;
      --font-display: 'Unbounded', sans-serif;
      --font-body: 'Manrope', sans-serif;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: var(--font-body);
      background: var(--color-cream);
      color: var(--color-dark);
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; }
    button, input, textarea, select { font-family: inherit; }
    ::selection { background: var(--color-orange); color: #FFFFFF; }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: rgba(31,41,37,0.15); border-radius: 8px; }
    
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-in { animation: fadeInUp 0.4s ease both; }
    .hidden { display: none !important; }
    .active-nav-btn {
      color: var(--color-green) !important;
      background: rgba(23, 107, 77, 0.09) !important;
      font-weight: 700 !important;
    }
    
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14.5px;
      font-weight: 600;
      color: var(--color-body-text);
      cursor: pointer;
      transition: all 0.15s ease;
      background: transparent;
      border: none;
      width: 100%;
      text-align: left;
    }
    .sidebar-link:hover {
      background: rgba(31, 41, 37, 0.04);
      color: var(--color-dark);
    }
    
    .nav-desktop-only { display: flex; }
    .nav-mobile-only { display: none; }
    @media (max-width: 980px) {
      .nav-desktop-only { display: none; }
      .nav-mobile-only { display: flex; }
    }
  </style>
</head>
<body>

  <!-- APP SHELL -->
  <div id="app-shell-view" style="display:flex; min-height:100vh;">
    
    <!-- SIDEBAR DESKTOP -->
    <aside class="nav-desktop-only" style="width:260px; flex-shrink:0; background:#FFFFFF; border-right:1px solid rgba(31,41,37,0.08); display:flex; flex-direction:column; height:100vh; position:sticky; top:0;">
      <div style="padding:22px 20px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(31,41,37,0.06);">
        <div style="width:38px; height:38px; border-radius:11px; background:#176B4D; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:12px; color:#FFFFFF;">ANB</span>
        </div>
        <div style="flex:1; min-width:0;">
          <div style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:14.5px; color:#176B4D; white-space:nowrap;">Espace ANB</div>
          <div style="font-size:11px; color:#5a655f; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Éditeur / Bénévole</div>
        </div>
      </div>
      
      <nav id="desktop-sidebar-nav" style="flex:1; overflow-y:auto; padding:16px 12px; display:flex; flex-direction:column; gap:4px;">
        <!-- Dynamically rendered -->
      </nav>
      
      <div style="padding:16px; border-top:1px solid rgba(31,41,37,0.06); display:flex; align-items:center; gap:12px;">
        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824); flex-shrink:0;"></div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:13.5px; font-weight:700; color:#1F2925; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Fatou Ibrahim</div>
          <div style="font-size:11.5px; color:#5a655f;">Éditeur</div>
        </div>
        <button class="logout-btn" aria-label="Déconnexion" style="width:34px; height:34px; border-radius:10px; background:#F8F4EC; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.8"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"></path><path d="M16 17l5-5-5-5"></path><path d="M21 12H9"></path></svg>
        </button>
      </div>
    </aside>

    <!-- MOBILE DRAWER -->
    <div id="mobile-sidebar-drawer" class="hidden" style="position:fixed; inset:0; z-index:300; background:#FFFFFF; display:flex; flex-direction:column; overflow-y:auto;">
      <div style="padding:20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid rgba(31,41,37,0.06);">
        <div style="display:flex; align-items:center; gap:12px;">
          <div style="width:38px; height:38px; border-radius:11px; background:#176B4D; display:flex; align-items:center; justify-content:center;">
            <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:12px; color:#FFFFFF;">ANB</span>
          </div>
          <div style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:14.5px; color:#176B4D; white-space:nowrap;">Espace ANB</div>
        </div>
        <button id="close-mobile-drawer" aria-label="Fermer" style="width:40px; height:40px; border-radius:10px; background:#F8F4EC; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="2"><line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line></svg>
        </button>
      </div>
      <nav id="mobile-sidebar-nav" style="flex:1; padding:16px; display:flex; flex-direction:column; gap:4px;">
        <!-- Dynamically rendered -->
      </nav>
      <div style="padding:16px; border-top:1px solid rgba(31,41,37,0.06);">
        <button class="logout-btn" style="width:100%; background:#F8F4EC; border:none; padding:14px; border-radius:12px; font-weight:700; font-size:14px; cursor:pointer; color:#1F2925;">Se déconnecter</button>
      </div>
    </div>

    <!-- MAIN COLUMN -->
    <div style="flex:1; min-width:0; display:flex; flex-direction:column;">
      
      <!-- TOP BAR -->
      <div style="position:sticky; top:0; z-index:50; background:rgba(248,244,236,0.92); backdrop-filter:blur(8px); border-bottom:1px solid rgba(31,41,37,0.08); padding:16px clamp(16px,3vw,32px); display:flex; align-items:center; gap:16px;">
        <button id="open-mobile-drawer" class="nav-mobile-only" aria-label="Menu" style="width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.1); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        <div style="flex:1; min-width:0;">
          <div style="font-size:12px; color:#5a655f; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Espace ANB / <span id="breadcrumb-page-label">Tableau de bord</span></div>
          <div id="title-page-label" style="font-size:17px; font-weight:800; color:#1F2925; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Tableau de bord</div>
        </div>
        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824); flex-shrink:0;"></div>
      </div>

      <!-- VIEWS CONTAINER -->
      <div style="flex:1; padding:clamp(18px,3vw,32px);">
        
        <!-- EDASH VIEW -->
        <section id="view-edash" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:24px;">
            <div>
              <h1 style="font-size:24px; font-weight:800; color:#1F2925; margin:0 0 6px;">Bonjour Fatou 👋</h1>
              <p style="font-size:14.5px; color:#5a655f; margin:0;">Vos contributions attendent d'être publiées.</p>
            </div>
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px;">
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#5a655f;">2</div><div style="font-size:13px; color:#5a655f;">Brouillons</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#E97824;">1</div><div style="font-size:13px; color:#5a655f;">En attente de validation</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#B14524;">1</div><div style="font-size:13px; color:#5a655f;">Renvoyé avec commentaire</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#176B4D;">1</div><div style="font-size:13px; color:#5a655f;">Publiés</div></div>
            </div>
            <div style="background:rgba(23,107,77,0.06); border-radius:16px; padding:18px; font-size:13.5px; color:#1F2925;">En tant qu'Éditeur, vous pouvez créer des brouillons d'articles, d'événements et de ressources. Ils seront publiés après validation par un Admin ou un Super Admin. Vous n'avez pas accès aux adhésions, messages privés ni aux statistiques détaillées.</div>
            <button class="nav-trigger-btn" data-page="econtenus" style="align-self:flex-start; background:#E97824; color:#FFFFFF; border:none; padding:13px 24px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Nouveau brouillon</button>
          </div>
        </section>

        <!-- ECONTENUS VIEW -->
        <section id="view-econtenus" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <div style="display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:14px;">
              <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Mes contenus</h1>
              <button style="background:#E97824; color:#FFFFFF; border:none; padding:12px 22px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;" onclick="alert('Nouveau brouillon créé !')">Nouveau brouillon</button>
            </div>
            <div style="background:#FFFFFF; border-radius:20px; padding:8px; box-shadow:0 8px 24px rgba(31,41,37,0.05);" id="editor-contents-list">
              <!-- Dynamic -->
            </div>
          </div>
        </section>

        <!-- MON PROFIL VIEW -->
        <section id="view-profil" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px; max-width:600px;">
            <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Mon profil</h1>
            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05); display:flex; flex-direction:column; gap:16px;">
              <div style="display:flex; align-items:center; gap:16px;">
                <div style="width:56px; height:56px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824);"></div>
                <div>
                  <div style="font-size:16px; font-weight:700; color:#1F2925;">Fatou Ibrahim</div>
                  <div style="font-size:13px; color:#5a655f;">Éditeur</div>
                </div>
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Nom complet</label>
                <input id="profile-form-name" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px;" value="Fatou Ibrahim" />
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">E-mail</label>
                <input id="profile-form-email" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px;" placeholder="vous@anb-bordeaux.fr" value="fatou.ibrahim@anb-bordeaux.fr" />
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Rôle</label>
                <input readonly style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px; color:#9aa39c;" value="Éditeur" />
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Nouveau mot de passe</label>
                <input type="password" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px;" placeholder="••••••••" />
              </div>
              <button style="align-self:flex-start; background:#176B4D; color:#FFFFFF; border:none; padding:12px 24px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;" onclick="alert('Profil enregistré !')">Enregistrer</button>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>

  <script>
    // State management
    const state = {
      user: 'editeur',
      page: 'edash'
    };

    const navigationItems = [
      { key: 'edash', label: 'Tableau de bord' },
      { key: 'econtenus', label: 'Mes contenus' },
      { type: 'separator' },
      { key: 'profil', label: 'Mon profil' }
    ];

    const svgMap = {
      edash: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="8" height="8" rx="2"></rect><rect x="13" y="3" width="8" height="8" rx="2"></rect><rect x="3" y="13" width="8" height="8" rx="2"></rect><rect x="13" y="13" width="8" height="8" rx="2"></rect></svg>`,
      econtenus: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="16" rx="2"></rect><line x1="7" y1="9" x2="17" y2="9"></line><line x1="7" y1="13" x2="17" y2="13"></line></svg>`,
      profil: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="8" r="3.4"></circle><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"></path></svg>`
    };

    const editorContents = [
      { type: 'Article', title: "Portrait : parcours d'une étudiante nigérienne", status: 'En attente de validation', tone: 'o' },
      { type: 'Article', title: 'Recette : le riz au gras pas à pas', status: 'Brouillon', tone: 'n' },
      { type: 'Événement', title: 'Atelier couture traditionnelle', status: 'Renvoyé — voir commentaire', tone: 'r' },
      { type: 'Ressource', title: 'Guide : renouveler son titre de séjour', status: 'Publié', tone: 'g' }
    ];

    function getBadgeHtml(label, tone) {
      const map = {
        g: { bg: 'rgba(23,107,77,0.12)', color: '#176B4D' },
        o: { bg: 'rgba(233,120,36,0.16)', color: '#B75E12' },
        r: { bg: 'rgba(177,69,36,0.13)', color: '#B14524' },
        n: { bg: 'rgba(31,41,37,0.08)', color: '#5a655f' }
      };
      const c = map[tone] || map.n;
      return `<span style="background:${c.bg}; color:${c.color}; padding:4px 12px; border-radius:999px; font-size:12px; font-weight:700;">${label}</span>`;
    }

    document.addEventListener('DOMContentLoaded', () => {
      generateNav();
      goPage('edash');

      document.querySelectorAll('.logout-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          window.location.href = '/connexion';
        });
      });

      const openDrawerBtn = document.getElementById('open-mobile-drawer');
      const closeDrawerBtn = document.getElementById('close-mobile-drawer');
      const mobileDrawer = document.getElementById('mobile-sidebar-drawer');

      openDrawerBtn.addEventListener('click', () => {
        mobileDrawer.classList.remove('hidden');
      });
      closeDrawerBtn.addEventListener('click', () => {
        mobileDrawer.classList.add('hidden');
      });
    });

    function goPage(pageKey) {
      state.page = pageKey;
      
      document.querySelectorAll('.sidebar-link').forEach(link => {
        if (link.dataset.page === pageKey) {
          link.classList.add('active-nav-btn');
        } else {
          link.classList.remove('active-nav-btn');
        }
      });

      const pageTitleMap = {
        edash: 'Tableau de bord', econtenus: 'Mes contenus', profil: 'Mon profil'
      };

      document.getElementById('breadcrumb-page-label').textContent = pageTitleMap[pageKey] || '';
      document.getElementById('title-page-label').textContent = pageTitleMap[pageKey] || '';

      document.querySelectorAll('section[id^="view-"]').forEach(sec => {
        sec.classList.add('hidden');
      });
      
      const targetView = document.getElementById(`view-${pageKey}`);
      if (targetView) targetView.classList.remove('hidden');

      document.getElementById('mobile-sidebar-drawer').classList.add('hidden');

      renderPageDetails(pageKey);
    }

    function generateNav() {
      const desktopContainer = document.getElementById('desktop-sidebar-nav');
      const mobileContainer = document.getElementById('mobile-sidebar-nav');

      desktopContainer.innerHTML = '';
      mobileContainer.innerHTML = '';

      function createLink(item) {
        const link = document.createElement('a');
        link.className = 'sidebar-link';
        link.dataset.page = item.key;
        link.style.cursor = 'pointer';
        const svgContent = svgMap[item.key] || '';
        link.innerHTML = `${svgContent}<span>${item.label}</span>`;
        link.addEventListener('click', () => {
          goPage(item.key);
        });
        return link;
      }

      navigationItems.forEach(item => {
        if (item.type === 'separator') {
          const sep = document.createElement('div');
          sep.style.cssText = 'height:1px; background:rgba(31,41,37,0.07); margin:10px 6px;';
          desktopContainer.appendChild(sep);
          mobileContainer.appendChild(sep.cloneNode(true));
        } else {
          desktopContainer.appendChild(createLink(item));
          mobileContainer.appendChild(createLink(item));
        }
      });
    }

    function renderPageDetails(pageKey) {
      if (pageKey === 'econtenus') {
        renderEcontenus();
      }
    }

    function renderEcontenus() {
      const list = document.getElementById('editor-contents-list');
      list.innerHTML = '';

      editorContents.forEach(c => {
        const row = document.createElement('div');
        row.style.cssText = 'display:flex; align-items:center; gap:16px; padding:16px; border-bottom:1px solid rgba(31,41,37,0.06); flex-wrap:wrap;';
        row.innerHTML = `
          <span style="background:rgba(23,107,77,0.08); color:#176B4D; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:700;">${c.type}</span>
          <div style="flex:1; min-width:220px; font-size:14px; font-weight:700; color:#1F2925;">${c.title}</div>
          ${getBadgeHtml(c.status, c.tone)}
          <button style="background:#F8F4EC; border:none; padding:9px 16px; border-radius:9px; font-size:12.5px; font-weight:700; cursor:pointer; color:#1F2925;" onclick="alert('Soumission du brouillon : ${c.title}')">Soumettre</button>
        `;
        list.appendChild(row);
      });
    }

    // Bind navigations inside views
    document.querySelectorAll('.nav-trigger-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        goPage(btn.dataset.page);
      });
    });
  </script>

</body>
</html>
