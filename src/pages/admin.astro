            // UI adaptation
            document.querySelector('#view-actualites-new h1').textContent = "Modifier l'actualité";
            document.getElementById('publish-news-submit-btn').textContent = "Sauvegarder les modifications";
          }
        });

        container.appendChild(card);
      });
    }

