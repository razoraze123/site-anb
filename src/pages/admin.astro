---
export const prerender = false;

const user = await Astro.session?.get('user');
if (!user || !['admin', 'super_admin'].includes(user.role)) {
  return Astro.redirect('/connexion');
}
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Espace ANB — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --color-cream: #F8F4EC;
      --color-green: #176B4D;
      --color-orange: #E97824;
      --color-dark: #1F2925;
      --color-sand: #E8D8BF;
      --color-body-text: #3f4a45;
      --color-muted-text: #5a655f;
      --font-display: 'Unbounded', sans-serif;
      --font-body: 'Manrope', sans-serif;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: var(--font-body);
      background: var(--color-cream);
      color: var(--color-dark);
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; }
    button, input, textarea, select { font-family: inherit; }
    ::selection { background: var(--color-orange); color: #FFFFFF; }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: rgba(31,41,37,0.15); border-radius: 8px; }
    
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-in { animation: fadeInUp 0.4s ease both; }
    .hidden { display: none !important; }
    .active-nav-btn {
      color: var(--color-green) !important;
      background: rgba(23, 107, 77, 0.09) !important;
      font-weight: 700 !important;
    }
    
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14.5px;
      font-weight: 600;
      color: var(--color-body-text);
      cursor: pointer;
      transition: all 0.15s ease;
      background: transparent;
      border: none;
      width: 100%;
      text-align: left;
    }
    .sidebar-link:hover {
      background: rgba(31, 41, 37, 0.04);
      color: var(--color-dark);
    }
    
    .nav-desktop-only { display: flex; }
    .nav-mobile-only { display: none; }
    @media (max-width: 980px) {
      .nav-desktop-only { display: none; }
      .nav-mobile-only { display: flex; }
    }
  </style>
</head>
<body>

  <!-- APP SHELL -->
  <div id="app-shell-view" style="display:flex; min-height:100vh;">
    
    <!-- SIDEBAR DESKTOP -->
    <aside class="nav-desktop-only" style="width:260px; flex-shrink:0; background:#FFFFFF; border-right:1px solid rgba(31,41,37,0.08); display:flex; flex-direction:column; height:100vh; position:sticky; top:0;">
      <div style="padding:22px 20px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(31,41,37,0.06);">
        <div style="width:38px; height:38px; border-radius:11px; background:#176B4D; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:12px; color:#FFFFFF;">ANB</span>
        </div>
        <div style="flex:1; min-width:0;">
          <div style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:14.5px; color:#176B4D; white-space:nowrap;">Espace ANB</div>
          <div style="font-size:11px; color:#5a655f; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Admin</div>
        </div>
      </div>
      
      <nav id="desktop-sidebar-nav" style="flex:1; overflow-y:auto; padding:16px 12px; display:flex; flex-direction:column; gap:4px;">
        <!-- Dynamically rendered -->
      </nav>
      
      <div style="padding:16px; border-top:1px solid rgba(31,41,37,0.06); display:flex; align-items:center; gap:12px;">
        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824); flex-shrink:0;"></div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:13.5px; font-weight:700; color:#1F2925; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Mariama Souley</div>
          <div style="font-size:11.5px; color:#5a655f;">Admin</div>
        </div>
        <button class="logout-btn" aria-label="Déconnexion" style="width:34px; height:34px; border-radius:10px; background:#F8F4EC; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.8"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"></path><path d="M16 17l5-5-5-5"></path><path d="M21 12H9"></path></svg>
        </button>
      </div>
    </aside>

    <!-- MOBILE DRAWER -->
    <div id="mobile-sidebar-drawer" class="hidden" style="position:fixed; inset:0; z-index:300; background:#FFFFFF; display:flex; flex-direction:column; overflow-y:auto;">
      <div style="padding:20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid rgba(31,41,37,0.06);">
        <div style="display:flex; align-items:center; gap:12px;">
          <div style="width:38px; height:38px; border-radius:11px; background:#176B4D; display:flex; align-items:center; justify-content:center;">
            <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:12px; color:#FFFFFF;">ANB</span>
          </div>
          <div style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:14.5px; color:#176B4D; white-space:nowrap;">Espace ANB</div>
        </div>
        <button id="close-mobile-drawer" aria-label="Fermer" style="width:40px; height:40px; border-radius:10px; background:#F8F4EC; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="2"><line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line></svg>
        </button>
      </div>
      <nav id="mobile-sidebar-nav" style="flex:1; padding:16px; display:flex; flex-direction:column; gap:4px;">
        <!-- Dynamically rendered -->
      </nav>
      <div style="padding:16px; border-top:1px solid rgba(31,41,37,0.06);">
        <button class="logout-btn" style="width:100%; background:#F8F4EC; border:none; padding:14px; border-radius:12px; font-weight:700; font-size:14px; cursor:pointer; color:#1F2925;">Se déconnecter</button>
      </div>
    </div>

    <!-- MAIN COLUMN -->
    <div style="flex:1; min-width:0; display:flex; flex-direction:column;">
      
      <!-- TOP BAR -->
      <div style="position:sticky; top:0; z-index:50; background:rgba(248,244,236,0.92); backdrop-filter:blur(8px); border-bottom:1px solid rgba(31,41,37,0.08); padding:16px clamp(16px,3vw,32px); display:flex; align-items:center; gap:16px;">
        <button id="open-mobile-drawer" class="nav-mobile-only" aria-label="Menu" style="width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.1); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        <div style="flex:1; min-width:0;">
          <div style="font-size:12px; color:#5a655f; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Espace ANB / <span id="breadcrumb-page-label">Tableau de bord</span></div>
          <div id="title-page-label" style="font-size:17px; font-weight:800; color:#1F2925; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Tableau de bord</div>
        </div>
        <div class="nav-desktop-only" style="flex:1; max-width:340px; position:relative;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5a655f" stroke-width="1.8" style="position:absolute; left:14px; top:50%; transform:translateY(-50%);"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
          <input id="global-search-input" placeholder="Recherche globale…" style="width:100%; padding:11px 16px 11px 40px; border-radius:999px; border:1.5px solid #e3dccb; background:#FFFFFF; font-size:13.5px;" />
        </div>
        <button aria-label="Notifications" style="position:relative; width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.08); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.7"><path d="M18 8a6 6 0 10-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.7 21a2 2 0 01-3.4 0"></path></svg>
          <span style="position:absolute; top:6px; right:7px; width:8px; height:8px; border-radius:50%; background:#E97824; border:1.5px solid #FFFFFF;"></span>
        </button>
        <button class="nav-desktop-only" aria-label="Aide" style="width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.08); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.7"><circle cx="12" cy="12" r="9"></circle><path d="M9.5 9.5a2.5 2.5 0 014.9.8c0 1.7-2.4 1.8-2.4 3.7"></path><circle cx="12" cy="17.2" r="0.4" fill="#1F2925"></circle></svg>
        </button>
        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824); flex-shrink:0;"></div>
      </div>

      <!-- VIEWS CONTAINER -->
      <div style="flex:1; padding:clamp(18px,3vw,32px);">
        
        <!-- DASHBOARD VIEW -->
        <section id="view-dashboard" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:24px;">
            <div style="display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:16px;">
              <div>
                <h1 style="font-size:24px; font-weight:800; color:#1F2925; margin:0 0 6px;">Bonjour Mariama 👋</h1>
                <p style="font-size:14.5px; color:#5a655f; margin:0;">Voici ce qui se passe pour l'ANB aujourd'hui.</p>
              </div>
              <div style="display:flex; gap:12px; flex-wrap:wrap;">
                <button class="btn-create-news nav-trigger-btn" data-page="actualites-new" style="background:#E97824; color:#FFFFFF; border:none; padding:13px 22px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Créer un contenu</button>
                <button class="btn-create-event nav-trigger-btn" data-page="evenements-new" style="background:#FFFFFF; color:#176B4D; border:2px solid #176B4D; padding:11px 22px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Créer un événement</button>
              </div>
            </div>

            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px;">
              <div style="background:#FFFFFF; border-radius:18px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
                <div id="stat-events-count" style="font-size:26px; font-weight:800; color:#176B4D;">0</div>
                <div style="font-size:13.5px; color:#5a655f; margin-top:4px;">Événements enregistrés</div>
              </div>
              <div style="background:#FFFFFF; border-radius:18px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
                <div id="stat-members-count" style="font-size:26px; font-weight:800; color:#E97824;">0</div>
                <div style="font-size:13.5px; color:#5a655f; margin-top:4px;">Membres / Inscrits</div>
              </div>
              <div style="background:#FFFFFF; border-radius:18px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
                <div id="stat-news-count" style="font-size:26px; font-weight:800; color:#176B4D;">0</div>
                <div style="font-size:13.5px; color:#5a655f; margin-top:4px;">Actualités publiées</div>
              </div>
              <div style="background:#FFFFFF; border-radius:18px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
                <div id="stat-census-count" style="font-size:26px; font-weight:800; color:#176B4D;">0</div>
                <div style="font-size:13.5px; color:#5a655f; margin-top:4px;">Membres recensés</div>
              </div>
            </div>

            <div style="display:grid; grid-template-columns:1.6fr 1fr; gap:20px; align-items:start; flex-wrap:wrap;">
              <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05); min-width:0;">
                <h3 style="font-size:16.5px; font-weight:700; color:#1F2925; margin:0 0 18px;">À traiter en priorité</h3>
                <div id="priority-items-container" style="display:flex; flex-direction:column; gap:4px;">
                  <!-- Dynamic -->
                </div>
              </div>

              <div style="display:flex; flex-direction:column; gap:20px; min-width:0;">
                <div style="background:#FFFFFF; border-radius:20px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
                  <h3 id="calendar-month-label" style="font-size:15px; font-weight:700; color:#1F2925; margin:0 0 14px;">Calendrier</h3>
                  <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:6px; text-align:center;" id="dashboard-calendar">
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">L</div>
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">M</div>
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">M</div>
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">J</div>
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">V</div>
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">S</div>
                    <div style="font-size:11px; font-weight:700; color:#5a655f;">D</div>
                    <!-- cells dynamically added -->
                  </div>
                </div>
                <div style="background:#176B4D; border-radius:20px; padding:24px; color:#FFFFFF;">
                  <div style="font-size:12px; font-weight:700; color:#E97824; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:10px;">Prochain événement</div>
                  <h3 style="font-size:18px; font-weight:700; margin:0 0 10px;" id="next-event-title">Journée culturelle nigérienne</h3>
                  <div style="font-size:13.5px; opacity:0.85; margin-bottom:4px;" id="next-event-date">Samedi 20 septembre · 11h00</div>
                  <div style="font-size:13.5px; opacity:0.85; margin-bottom:14px;" id="next-event-place">Parc Bordelais, Bordeaux</div>
                  <button class="nav-trigger-btn" data-page="evenements" style="background:#E97824; color:#FFFFFF; border:none; padding:12px 22px; border-radius:999px; font-weight:700; font-size:13.5px; cursor:pointer;">Gérer l'événement</button>
                </div>
              </div>
            </div>

            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
              <h3 style="font-size:16.5px; font-weight:700; color:#1F2925; margin:0 0 16px;">Activité récente</h3>
              <div style="display:flex; flex-direction:column; gap:14px;">
                <div style="display:flex; gap:12px; align-items:flex-start; font-size:14px; color:#3f4a45;">
                  <div style="width:8px; height:8px; border-radius:50%; background:#E97824; margin-top:7px; flex-shrink:0;"></div>
                  <div>Vous avez publié l'actualité « Bienvenue aux nouveaux membres »<span style="color:#9aa39c; font-size:12.5px; display:block; margin-top:2px;">Il y a 3 heures</span></div>
                </div>
                <div style="display:flex; gap:12px; align-items:flex-start; font-size:14px; color:#3f4a45;">
                  <div style="width:8px; height:8px; border-radius:50%; background:#E97824; margin-top:7px; flex-shrink:0;"></div>
                  <div>Fatou a ajouté 12 photos dans la galerie<span style="color:#9aa39c; font-size:12.5px; display:block; margin-top:2px;">Hier</span></div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ACTUALITES VIEW -->
        <section id="view-actualites" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <div style="display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:14px;">
              <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Actualités</h1>
              <button class="btn-create-news nav-trigger-btn" data-page="actualites-new" style="background:#E97824; color:#FFFFFF; border:none; padding:12px 22px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Nouvelle actualité</button>
            </div>
            <div style="display:flex; gap:8px; flex-wrap:wrap;" class="news-tab-container">
              <!-- tabs -->
            </div>
            <div style="background:#FFFFFF; border-radius:20px; padding:8px; box-shadow:0 8px 24px rgba(31,41,37,0.05);" id="news-list-container">
              <!-- list -->
            </div>
          </div>
        </section>

        <!-- NOUVELLE ACTUALITE VIEW -->
        <section id="view-actualites-new" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px; max-width:820px;">
            <div style="display:flex; align-items:center; gap:14px;">
              <button class="nav-trigger-btn" data-page="actualites" style="width:36px; height:36px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.1); cursor:pointer; display: flex; align-items: center; justify-content: center;">←</button>
              <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Nouvelle actualité</h1>
            </div>
            <div style="background:#FFFFFF; border-radius:20px; padding:28px; box-shadow:0 8px 24px rgba(31,41,37,0.05); display:flex; flex-direction:column; gap:18px;">
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Titre</label>
                <input id="news-form-title" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14.5px;" placeholder="Titre de l'article" />
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Slug / URL</label>
                <input id="news-form-slug" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14.5px; color:#9aa39c;" placeholder="/actualites/titre-de-larticle" readonly />
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Résumé court</label>
                <textarea id="news-form-excerpt" rows="2" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14.5px; resize:vertical;" placeholder="Résumé affiché dans les listes"></textarea>
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Contenu</label>
                <textarea id="news-form-content" rows="7" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14.5px; resize:vertical;" placeholder="Rédigez votre article ici…"></textarea>
              </div>
              <div>
                <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:8px;">Image de couverture</label>
                <div id="news-upload-zone" style="border:2px dashed #d8cfb8; border-radius:14px; padding:40px 30px; text-align:center; color:#9aa39c; font-size:13.5px; cursor:pointer; background:#FFFFFF; position:relative; overflow:hidden; transition:all 0.15s ease; display:flex; align-items:center; justify-content:center; min-height:140px;">
                  <span id="news-upload-placeholder" style="z-index:10;">Glissez-déposez une image ici, ou cliquez pour parcourir</span>
                </div>
                <input type="file" id="news-image-input" accept="image/*" style="display:none;" />
                <input type="hidden" id="news-form-image-url" />
              </div>
              <div style="display:flex; gap:14px; flex-wrap:wrap;">
                <div style="flex:1; min-width:180px;">
                  <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Catégorie</label>
                  <select id="news-form-category" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14.5px;">
                    <option>Communauté</option>
                    <option>Vie associative</option>
                    <option>Bénévolat</option>
                    <option>Culture</option>
                    <option>Solidarité</option>
                  </select>
                </div>
                <div style="flex:1; min-width:180px;">
                  <label style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Rédacteur</label>
                  <input id="news-form-author" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14.5px; color:#9aa39c;" value="Mariama Souley" readonly />
                </div>
              </div>
