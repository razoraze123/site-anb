    // Arrays populated dynamically via API
    let priorityItems = [];
    let newsArticles = [];
    let eventsAdmin = [];
    let registrants = [];
    let pendingInscriptionsEventId = null;
    let messages = [];
    let recensementList = [];
    let recensementSearch = '';

    async function fetchAdminData() {
      try {
        const response = await fetch('/api/admin/data');
        if (!response.ok) throw new Error("Erreur de récupération des données");
        
        const data = await response.json();
        
        newsArticles = data.actualites;
        eventsAdmin = data.evenements;
        registrants = data.inscriptions;
        messages = data.messages;
        recensementList = data.recensement || [];

        // Populate statistics indicators
        document.getElementById('stat-events-count').textContent = eventsAdmin.length;
        document.getElementById('stat-news-count').textContent = newsArticles.filter(n => n.status === 'Publié').length;
        document.getElementById('stat-members-count').textContent = registrants.filter(r => r.status === 'Confirmé').length;
        document.getElementById('stat-census-count').textContent = recensementList.length;

        // Update priority items
        priorityItems = [];

        messages.filter(m => m.status === 'Non lu' || m.status === 'À traiter').forEach(m => {
          priorityItems.push({
            id: m.id,
            name: m.from_name,
            type: m.subject,
            date: 'Reçu',
            status: m.status,
            tone: 'o',
            avatarBg: 'linear-gradient(150deg,#E97824,#1F2925)',
            action: 'messages'
          });
        });

        // Next event update
        const nextEvent = eventsAdmin.find(e => e.tab === 'À venir');
        if (nextEvent) {
          document.getElementById('next-event-title').textContent = nextEvent.title;
          document.getElementById('next-event-date').textContent = nextEvent.date;
          document.getElementById('next-event-place').textContent = nextEvent.place;
          
          document.getElementById('promo-event-title').textContent = nextEvent.title;
          
          const coverPromo = document.getElementById('promo-event-cover');
          if (coverPromo) {
            const isUrl = nextEvent.bg_gradient.startsWith('/') || nextEvent.bg_gradient.startsWith('http');
            if (isUrl) {
              coverPromo.style.background = `url('${nextEvent.bg_gradient}') center/cover no-repeat`;
            } else {
              coverPromo.style.background = nextEvent.bg_gradient;
            }
          }

          document.getElementById('promo-event-details').textContent = `${nextEvent.date} · ${nextEvent.place} · ${nextEvent.registered_count}/${nextEvent.max_places} inscrits`;
        }

        // Re-render current page
        renderPageDetails(state.page);

      } catch (err) {
        console.error("Erreur D1 : ", err);
      }
    }

    function getBadgeHtml(label, tone) {
      const map = {
        g: { bg: 'rgba(23,107,77,0.12)', color: '#176B4D' },
        o: { bg: 'rgba(233,120,36,0.16)', color: '#B75E12' },
        r: { bg: 'rgba(177,69,36,0.13)', color: '#B14524' },
        n: { bg: 'rgba(31,41,37,0.08)', color: '#5a655f' }
      };
      const c = map[tone] || map.n;
      return `<span style="background:${c.bg}; color:${c.color}; padding:4px 12px; border-radius:999px; font-size:12px; font-weight:700;">${label}</span>`;
    }

    function goPage(pageKey) {
      state.page = pageKey;
      
      document.querySelectorAll('.sidebar-link').forEach(link => {
        if (link.dataset.page === pageKey) {
          link.classList.add('active-nav-btn');
