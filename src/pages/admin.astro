            state.editingNewsId = art.id;
            goPage('actualites-new');
            
            // Populate form
            document.getElementById('news-form-title').value = art.title;
            document.getElementById('news-form-slug').value = '/actualites/' + art.slug;
            document.getElementById('news-form-excerpt').value = art.excerpt;
            document.getElementById('news-form-content').value = art.content;
            document.getElementById('news-form-category').value = art.category;

            // Handle image R2 check
            if (art.bg_gradient && (art.bg_gradient.startsWith('/') || art.bg_gradient.startsWith('http'))) {
              setUploadPreview('news', art.bg_gradient);
