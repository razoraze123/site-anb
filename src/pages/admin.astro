    // 10. Statistiques
    function renderStats() {
      const periodsWrapper = document.querySelector('.stats-period-container');
      periodsWrapper.innerHTML = '';
      const periodDefs = ['7 jours', '30 jours', '3 mois', '1 an'];

      periodDefs.forEach(p => {
        const btn = document.createElement('button');
        btn.style.cssText = `border:2px solid #176B4D; padding:8px 16px; border-radius:999px; font-weight:700; font-size:13px; cursor:pointer;`;
        if (state.statsPeriod === p) {
          btn.style.background = '#176B4D'; btn.style.color = '#FFFFFF';
        } else {
          btn.style.background = 'transparent'; btn.style.color = '#176B4D';
        }
        btn.textContent = p;
        btn.addEventListener('click', () => {
          state.statsPeriod = p; renderStats();
        });
        periodsWrapper.appendChild(btn);
      });

      const barsWrapper = document.getElementById('visit-bars-container');
      barsWrapper.innerHTML = '';
      const visitHeights = {
        '7 jours': [45, 60, 50, 75, 60, 90, 70],
        '30 jours': [65, 80, 55, 90, 75, 100, 85],
        '3 mois': [50, 55, 45, 70, 65, 80, 75],
        '1 an': [30, 45, 40, 60, 50, 75, 65]
      };
      
      const heights = visitHeights[state.statsPeriod] || visitHeights['30 jours'];
      const days = ['L','M','M','J','V','S','D'];

      heights.forEach((h, idx) => {
        const barCol = document.createElement('div');
        barCol.style.cssText = 'flex:1; display:flex; flex-direction:column; align-items:center; gap:8px; height:100%; justify-content:flex-end;';
        barCol.innerHTML = `
          <div style="width:100%; max-width:32px; height:${h}%; background:#176B4D; border-radius:8px 8px 0 0; transition: height 0.3s ease;"></div>
          <span style="font-size:11px; color:#9aa39c;">${days[idx]}</span>
        `;
        barsWrapper.appendChild(barCol);
      });
    }

    // MAIN DOM LISTENERS AND SELECTORS SAFELY WRAPPED
    document.addEventListener('DOMContentLoaded', async () => {
      // Nav structure init
      generateNav();
      
      // Load D1 data
      await fetchAdminData();
      
      // Open dashboard
      goPage('dashboard');

      // Logout handler
      document.querySelectorAll('.logout-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          await fetch('/api/logout', { method: 'POST' });
          window.location.href = '/connexion';
        });
      });

      // Mobile Drawer actions
      const openDrawerBtn = document.getElementById('open-mobile-drawer');
      const closeDrawerBtn = document.getElementById('close-mobile-drawer');
      const mobileDrawer = document.getElementById('mobile-sidebar-drawer');

      if (openDrawerBtn && mobileDrawer) {
        openDrawerBtn.addEventListener('click', () => {
          mobileDrawer.classList.remove('hidden');
        });
      }
      if (closeDrawerBtn && mobileDrawer) {
        closeDrawerBtn.addEventListener('click', () => {
          mobileDrawer.classList.add('hidden');
        });
      }

      // Title to Slug automatic typing listener
      const titleFormInput = document.getElementById('news-form-title');
      const slugFormInput = document.getElementById('news-form-slug');
      if (titleFormInput && slugFormInput) {
        titleFormInput.addEventListener('input', (e) => {
          // Only generate slug automatically if we are NOT editing
          if (!state.editingNewsId) {
            slugFormInput.value = '/actualites/' + e.target.value
              .toLowerCase()
              .trim()
              .normalize("NFD")
              .replace(/[\u0300-\u036f]/g, "") // Remove accents
              .replace(/[^a-z0-9]+/g, '-');
          }
        });
      }

      // Recensement Search listener
      const recSearchInput = document.getElementById('recensement-search-input');
      if (recSearchInput) {
        recSearchInput.addEventListener('input', (e) => {
          recensementSearch = e.target.value;
          renderRecensement();
        });
      }

      // Recensement Status tabs listeners
      document.querySelectorAll('.rec-tab-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          document.querySelectorAll('.rec-tab-btn').forEach(b => {
            b.style.background = '#F8F4EC';
            b.style.color = '#1F2925';
          });
          e.target.style.background = '#176B4D';
          e.target.style.color = '#FFFFFF';
          state.recensementFilter = e.target.dataset.status;
          renderRecensement();
        });
      });

      // Recensement Export CSV
      const recExportBtn = document.getElementById('recensement-export-csv-btn');
      if (recExportBtn) {
        recExportBtn.addEventListener('click', () => {
          if (recensementList.length === 0) {
            alert("Aucune donnée à exporter.");
            return;
          }
          const headers = ["ID", "Prénom", "Nom", "Statut", "Téléphone", "E-mail", "Domaine", "Bénévole", "Date d'inscription"];
          const csvRows = [headers.join(";")];
          recensementList.forEach(r => {
            csvRows.push([
              r.id, r.first_name, r.last_name, r.status, r.phone, r.email,
              r.domaine || '',
              r.benevole ? 'Oui' : 'Non',
              r.created_at
            ].join(";"));
          });
          const blob = new Blob(["\uFEFF" + csvRows.join("\n")], { type: 'text/csv;charset=utf-8;' });
          const url = URL.createObjectURL(blob);
          const link = document.createElement("a");
          link.setAttribute("href", url);
          link.setAttribute("download", `recensement_anb_${new Date().toISOString().split('T')[0]}.csv`);
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
        });
      }

      // Hook up interactive R2 upload zone for News
      const newsUploadZone = document.getElementById('news-upload-zone');
      const newsImageInput = document.getElementById('news-image-input');
      if (newsUploadZone && newsImageInput) {
        newsUploadZone.addEventListener('click', () => {
          newsImageInput.click();
        });
        newsUploadZone.addEventListener('dragover', (e) => {
          e.preventDefault();
          newsUploadZone.style.borderColor = '#176B4D';
          newsUploadZone.style.background = 'rgba(23,107,77,0.03)';
        });
        newsUploadZone.addEventListener('dragleave', () => {
          newsUploadZone.style.borderColor = '#d8cfb8';
          newsUploadZone.style.background = '#FFFFFF';
        });
        newsUploadZone.addEventListener('drop', (e) => {
          e.preventDefault();
          newsUploadZone.style.borderColor = '#d8cfb8';
          newsUploadZone.style.background = '#FFFFFF';
          if (e.dataTransfer.files && e.dataTransfer.files[0]) {
            handleImageUpload(e.dataTransfer.files[0], 'news');
          }
        });
        newsImageInput.addEventListener('change', (e) => {
          if (e.target.files && e.target.files[0]) {
            handleImageUpload(e.target.files[0], 'news');
          }
        });
      }

      // Hook up interactive R2 upload zone for Events
      const eventUploadZone = document.getElementById('event-upload-zone');
      const eventImageInput = document.getElementById('event-image-input');
      if (eventUploadZone && eventImageInput) {
        eventUploadZone.addEventListener('click', () => {
          eventImageInput.click();
        });
        eventUploadZone.addEventListener('dragover', (e) => {
          e.preventDefault();
          eventUploadZone.style.borderColor = '#176B4D';
          eventUploadZone.style.background = 'rgba(23,107,77,0.03)';
        });
        eventUploadZone.addEventListener('dragleave', () => {
          eventUploadZone.style.borderColor = '#d8cfb8';
          eventUploadZone.style.background = '#FFFFFF';
        });
        eventUploadZone.addEventListener('drop', (e) => {
          e.preventDefault();
          eventUploadZone.style.borderColor = '#d8cfb8';
          eventUploadZone.style.background = '#FFFFFF';
          if (e.dataTransfer.files && e.dataTransfer.files[0]) {
            handleImageUpload(e.dataTransfer.files[0], 'event');
          }
        });
        eventImageInput.addEventListener('change', (e) => {
          if (e.target.files && e.target.files[0]) {
            handleImageUpload(e.target.files[0], 'event');
          }
        });
      }

      // News Publish Submission
      const publishNewsBtn = document.getElementById('publish-news-submit-btn');
      if (publishNewsBtn) {
        publishNewsBtn.addEventListener('click', async () => {
          const titleVal = titleFormInput ? titleFormInput.value.trim() : '';
          const slugVal = slugFormInput ? slugFormInput.value.trim() : '';
          const excerptVal = document.getElementById('news-form-excerpt') ? document.getElementById('news-form-excerpt').value.trim() : '';
          const contentVal = document.getElementById('news-form-content') ? document.getElementById('news-form-content').value.trim() : '';
          const categoryVal = document.getElementById('news-form-category') ? document.getElementById('news-form-category').value : 'Communauté';
          const r2ImageUrl = document.getElementById('news-form-image-url') ? document.getElementById('news-form-image-url').value : '';

          if (!titleVal || !excerptVal || !contentVal) {
            alert('Veuillez remplir le titre, le résumé et le contenu de l\'actualité.');
            return;
          }

          const isEdit = state.editingNewsId !== null;
          const url = isEdit ? '/api/admin/news' : '/api/admin/news';
          const method = isEdit ? 'PUT' : 'POST';

          // Default gradient if no image uploaded
          const finalCover = r2ImageUrl || 'linear-gradient(150deg,#176B4D,#1F2925)';

          try {
            const res = await fetch(url, {
              method: method,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                id: state.editingNewsId, // will be ignored by POST
                title: titleVal,
                slug: slugVal.replace('/actualites/', ''), // extract raw slug
                excerpt: excerptVal,
                content: contentVal,
                category: categoryVal,
                auteur_id: 2, // Mariama Souley
                status: 'Publié',
                bg_gradient: finalCover
              })
            });

            if (!res.ok) {
              const errBody = await res.json();
              throw new Error(errBody.error || "Erreur lors de l'enregistrement");
            }

            document.getElementById('news-publish-success-alert').classList.remove('hidden');
            await fetchAdminData();
            
            setTimeout(() => {
              document.getElementById('news-publish-success-alert').classList.add('hidden');
              if (titleFormInput) titleFormInput.value = '';
              if (slugFormInput) slugFormInput.value = '';
              if (document.getElementById('news-form-excerpt')) document.getElementById('news-form-excerpt').value = '';
              if (document.getElementById('news-form-content')) document.getElementById('news-form-content').value = '';
              resetUploadZone('news');
              state.editingNewsId = null;
              goPage('actualites');
            }, 1200);

          } catch (err) {
            alert("Erreur de sauvegarde : " + err.message);
          }
        });
      }

      // Event Publish Submission
      const publishEventBtn = document.getElementById('publish-event-submit-btn');
      if (publishEventBtn) {
        publishEventBtn.addEventListener('click', async () => {
          const titleVal = document.getElementById('event-form-title') ? document.getElementById('event-form-title').value.trim() : '';
          const dateVal = document.getElementById('event-form-date') ? document.getElementById('event-form-date').value.trim() : '';
          const placeVal = document.getElementById('event-form-place') ? document.getElementById('event-form-place').value.trim() : '';
          const categoryVal = document.getElementById('event-form-category') ? document.getElementById('event-form-category').value : 'Culture';
          const maxPlacesVal = document.getElementById('event-form-places') ? parseInt(document.getElementById('event-form-places').value) : 100;
          const descVal = document.getElementById('event-form-desc') ? document.getElementById('event-form-desc').value.trim() : '';
          const r2ImageUrl = document.getElementById('event-form-image-url') ? document.getElementById('event-form-image-url').value : '';

          if (!titleVal || !dateVal || !placeVal) {
            alert('Veuillez remplir le titre, la date et le lieu du nouvel événement.');
            return;
          }

          const isEdit = state.editingEventId !== null;
          const url = isEdit ? '/api/admin/events' : '/api/admin/events';
          const method = isEdit ? 'PUT' : 'POST';

          // Default gradient if no image uploaded
          const finalCover = r2ImageUrl || 'linear-gradient(150deg,#E97824,#1F2925)';

          try {
            const res = await fetch(url, {
              method: method,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                id: state.editingEventId,
                title: titleVal,
                date: dateVal,
                place: placeVal,
                category: categoryVal,
                max_places: maxPlacesVal,
                status: 'Ouvert',
                bg_gradient: finalCover
              })
            });

            if (!res.ok) {
              const errBody = await res.json();
              throw new Error(errBody.error || "Erreur de création serveur");
            }

            const successAlert = document.getElementById('event-publish-success-alert');
            if (successAlert) successAlert.classList.remove('hidden');
            await fetchAdminData();
            
            setTimeout(() => {
              if (successAlert) successAlert.classList.add('hidden');
              if (document.getElementById('event-form-title')) document.getElementById('event-form-title').value = '';
              if (document.getElementById('event-form-date')) document.getElementById('event-form-date').value = '';
              if (document.getElementById('event-form-place')) document.getElementById('event-form-place').value = '';
              if (document.getElementById('event-form-desc')) document.getElementById('event-form-desc').value = '';
              resetUploadZone('event');
              state.editingEventId = null;
              goPage('evenements');
            }, 1200);

          } catch (err) {
            alert("Erreur de sauvegarde : " + err.message);
          }
        });
      }

      // Mobile FAB Trigger
      const mobileFabBtn = document.getElementById('mobile-fab-btn');
      if (mobileFabBtn) {
        mobileFabBtn.addEventListener('click', () => {
          state.editingNewsId = null;
          resetUploadZone('news');
          goPage('actualites-new');
        });
      }

      // Bind all creation shortcuts in views
      document.querySelectorAll('.btn-create-news').forEach(btn => {
        btn.addEventListener('click', () => {
          state.editingNewsId = null;
          document.querySelector('#view-actualites-new h1').textContent = "Nouvelle actualité";
          document.getElementById('publish-news-submit-btn').textContent = "Publier l'actualité";
          if (titleFormInput) titleFormInput.value = '';
          if (slugFormInput) slugFormInput.value = '';
          if (document.getElementById('news-form-excerpt')) document.getElementById('news-form-excerpt').value = '';
          if (document.getElementById('news-form-content')) document.getElementById('news-form-content').value = '';
          resetUploadZone('news');
        });
      });

      document.querySelectorAll('.btn-create-event').forEach(btn => {
        btn.addEventListener('click', () => {
          state.editingEventId = null;
          document.querySelector('#view-evenements-new h1').textContent = "Créer un événement";
          document.getElementById('publish-event-submit-btn').textContent = "Publier l'événement";
          if (document.getElementById('event-form-title')) document.getElementById('event-form-title').value = '';
          if (document.getElementById('event-form-date')) document.getElementById('event-form-date').value = '';
          if (document.getElementById('event-form-place')) document.getElementById('event-form-place').value = '';
          if (document.getElementById('event-form-desc')) document.getElementById('event-form-desc').value = '';
          resetUploadZone('event');
        });
      });

      // General nav triggers (buttons)
      document.querySelectorAll('.nav-trigger-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          goPage(btn.dataset.page);
        });
      });
    });
  </script>

</body>
</html>
