            if (document.getElementById('event-form-date')) document.getElementById('event-form-date').value = '';
            if (document.getElementById('event-form-place')) document.getElementById('event-form-place').value = '';
            if (document.getElementById('event-form-desc')) document.getElementById('event-form-desc').value = '';
