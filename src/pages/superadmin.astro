    function goPage(pageKey) {
      state.page = pageKey;
      
      document.querySelectorAll('.sidebar-link').forEach(link => {
        if (link.dataset.page === pageKey) {
          link.classList.add('active-nav-btn');
        } else {
          link.classList.remove('active-nav-btn');
        }
      });

      const pageTitleMap = {
        overview: "Vue d'ensemble", users: 'Utilisateurs & rôles', contenus: 'Contenus & validations',
        donnees: 'Données & exports', journal: "Journal d'activité", reglages: 'Réglages du site',
        integrations: 'Intégrations', securite: 'Sécurité', sauvegardes: 'Sauvegardes',
        mentions: 'Mentions & RGPD', stats: 'Statistiques globales', profil: 'Mon profil'
      };

      document.getElementById('breadcrumb-page-label').textContent = pageTitleMap[pageKey] || '';
      document.getElementById('title-page-label').textContent = pageTitleMap[pageKey] || '';

      document.querySelectorAll('section[id^="view-"]').forEach(sec => {
        sec.classList.add('hidden');
      });
      
      const targetView = document.getElementById(`view-${pageKey}`);
      if (targetView) targetView.classList.remove('hidden');

      document.getElementById('mobile-sidebar-drawer').classList.add('hidden');

      renderPageDetails(pageKey);
    }

    function generateNav() {
      const desktopContainer = document.getElementById('desktop-sidebar-nav');
      const mobileContainer = document.getElementById('mobile-sidebar-nav');

      desktopContainer.innerHTML = '';
      mobileContainer.innerHTML = '';

      function createLink(item) {
        const link = document.createElement('a');
        link.className = 'sidebar-link';
        link.dataset.page = item.key;
        link.style.cursor = 'pointer';
        const svgContent = svgMap[item.key] || '';
        link.innerHTML = `${svgContent}<span>${item.label}</span>`;
        link.addEventListener('click', () => {
          goPage(item.key);
        });
        return link;
      }

      navigationItems.forEach(item => {
        if (item.type === 'header') {
          const header = document.createElement('div');
          header.style.cssText = 'font-size:11px; font-weight:700; color:#9aa39c; text-transform:uppercase; letter-spacing:0.05em; padding:16px 14px 6px;';
          header.textContent = item.label;
          desktopContainer.appendChild(header);
          mobileContainer.appendChild(header.cloneNode(true));
        } else if (item.type === 'separator') {
          const sep = document.createElement('div');
          sep.style.cssText = 'height:1px; background:rgba(31,41,37,0.07); margin:10px 6px;';
          desktopContainer.appendChild(sep);
          mobileContainer.appendChild(sep.cloneNode(true));
        } else {
          desktopContainer.appendChild(createLink(item));
          mobileContainer.appendChild(createLink(item));
        }
      });
    }

