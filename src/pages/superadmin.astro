<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Espace ANB — Super Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --color-cream: #F8F4EC;
      --color-green: #176B4D;
      --color-orange: #E97824;
      --color-dark: #1F2925;
      --color-sand: #E8D8BF;
      --color-body-text: #3f4a45;
      --color-muted-text: #5a655f;
      --font-display: 'Unbounded', sans-serif;
      --font-body: 'Manrope', sans-serif;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: var(--font-body);
      background: var(--color-cream);
      color: var(--color-dark);
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; }
    button, input, textarea, select { font-family: inherit; }
    ::selection { background: var(--color-orange); color: #FFFFFF; }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: rgba(31,41,37,0.15); border-radius: 8px; }
    
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-in { animation: fadeInUp 0.4s ease both; }
    .hidden { display: none !important; }
    .active-nav-btn {
      color: var(--color-green) !important;
      background: rgba(23, 107, 77, 0.09) !important;
      font-weight: 700 !important;
    }
    
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14.5px;
      font-weight: 600;
      color: var(--color-body-text);
      cursor: pointer;
      transition: all 0.15s ease;
      background: transparent;
      border: none;
      width: 100%;
      text-align: left;
    }
    .sidebar-link:hover {
      background: rgba(31, 41, 37, 0.04);
      color: var(--color-dark);
    }
    
    .nav-desktop-only { display: flex; }
    .nav-mobile-only { display: none; }
    @media (max-width: 980px) {
      .nav-desktop-only { display: none; }
      .nav-mobile-only { display: flex; }
    }
  </style>
</head>
<body>

  <!-- APP SHELL -->
  <div id="app-shell-view" style="display:flex; min-height:100vh;">
    
    <!-- SIDEBAR DESKTOP -->
    <aside class="nav-desktop-only" style="width:260px; flex-shrink:0; background:#FFFFFF; border-right:1px solid rgba(31,41,37,0.08); display:flex; flex-direction:column; height:100vh; position:sticky; top:0;">
      <div style="padding:22px 20px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(31,41,37,0.06);">
        <div style="width:38px; height:38px; border-radius:11px; background:#176B4D; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:12px; color:#FFFFFF;">ANB</span>
        </div>
        <div style="flex:1; min-width:0;">
          <div style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:14.5px; color:#176B4D; white-space:nowrap;">Espace ANB</div>
          <div style="font-size:11px; color:#5a655f; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Super Admin</div>
        </div>
      </div>
      
      <nav id="desktop-sidebar-nav" style="flex:1; overflow-y:auto; padding:16px 12px; display:flex; flex-direction:column; gap:4px;">
        <!-- Dynamically rendered -->
      </nav>
      
      <div style="padding:16px; border-top:1px solid rgba(31,41,37,0.06); display:flex; align-items:center; gap:12px;">
        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824); flex-shrink:0;"></div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:13.5px; font-weight:700; color:#1F2925; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Nasser Diallo</div>
          <div style="font-size:11.5px; color:#5a655f;">Super Admin</div>
        </div>
        <button class="logout-btn" aria-label="Déconnexion" style="width:34px; height:34px; border-radius:10px; background:#F8F4EC; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.8"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"></path><path d="M16 17l5-5-5-5"></path><path d="M21 12H9"></path></svg>
        </button>
      </div>
    </aside>

    <!-- MOBILE DRAWER -->
    <div id="mobile-sidebar-drawer" class="hidden" style="position:fixed; inset:0; z-index:300; background:#FFFFFF; display:flex; flex-direction:column; overflow-y:auto;">
      <div style="padding:20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid rgba(31,41,37,0.06);">
        <div style="display:flex; align-items:center; gap:12px;">
          <div style="width:38px; height:38px; border-radius:11px; background:#176B4D; display:flex; align-items:center; justify-content:center;">
            <span style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:12px; color:#FFFFFF;">ANB</span>
          </div>
          <div style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:14.5px; color:#176B4D; white-space:nowrap;">Espace ANB</div>
        </div>
        <button id="close-mobile-drawer" aria-label="Fermer" style="width:40px; height:40px; border-radius:10px; background:#F8F4EC; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="2"><line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line></svg>
        </button>
      </div>
      <nav id="mobile-sidebar-nav" style="flex:1; padding:16px; display:flex; flex-direction:column; gap:4px;">
        <!-- Dynamically rendered -->
      </nav>
      <div style="padding:16px; border-top:1px solid rgba(31,41,37,0.06);">
        <button class="logout-btn" style="width:100%; background:#F8F4EC; border:none; padding:14px; border-radius:12px; font-weight:700; font-size:14px; cursor:pointer; color:#1F2925;">Se déconnecter</button>
      </div>
    </div>

    <!-- MAIN COLUMN -->
    <div style="flex:1; min-width:0; display:flex; flex-direction:column;">
      
      <!-- TOP BAR -->
      <div style="position:sticky; top:0; z-index:50; background:rgba(248,244,236,0.92); backdrop-filter:blur(8px); border-bottom:1px solid rgba(31,41,37,0.08); padding:16px clamp(16px,3vw,32px); display:flex; align-items:center; gap:16px;">
        <button id="open-mobile-drawer" class="nav-mobile-only" aria-label="Menu" style="width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.1); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        <div style="flex:1; min-width:0;">
          <div style="font-size:12px; color:#5a655f; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Espace ANB / <span id="breadcrumb-page-label">Vue d'ensemble</span></div>
          <div id="title-page-label" style="font-size:17px; font-weight:800; color:#1F2925; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Vue d'ensemble</div>
        </div>
        <div class="nav-desktop-only" style="flex:1; max-width:340px; position:relative;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5a655f" stroke-width="1.8" style="position:absolute; left:14px; top:50%; transform:translateY(-50%);"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
          <input id="global-search-input" placeholder="Recherche globale…" style="width:100%; padding:11px 16px 11px 40px; border-radius:999px; border:1.5px solid #e3dccb; background:#FFFFFF; font-size:13.5px;" />
        </div>
        <button aria-label="Notifications" style="position:relative; width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.08); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.7"><path d="M18 8a6 6 0 10-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.7 21a2 2 0 01-3.4 0"></path></svg>
          <span style="position:absolute; top:6px; right:7px; width:8px; height:8px; border-radius:50%; background:#E97824; border:1.5px solid #FFFFFF;"></span>
        </button>
        <button class="nav-desktop-only" aria-label="Aide" style="width:40px; height:40px; border-radius:10px; background:#FFFFFF; border:1px solid rgba(31,41,37,0.08); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1F2925" stroke-width="1.7"><circle cx="12" cy="12" r="9"></circle><path d="M9.5 9.5a2.5 2.5 0 014.9.8c0 1.7-2.4 1.8-2.4 3.7"></path><circle cx="12" cy="17.2" r="0.4" fill="#1F2925"></circle></svg>
        </button>
        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(150deg,#176B4D,#E97824); flex-shrink:0;"></div>
      </div>

      <!-- VIEWS CONTAINER -->
      <div style="flex:1; padding:clamp(18px,3vw,32px);">
        
        <!-- OVERVIEW VIEW -->
        <section id="view-overview" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:24px;">
            <div>
              <h1 style="font-size:24px; font-weight:800; color:#1F2925; margin:0 0 6px;">Bonjour Nasser 👋</h1>
              <p style="font-size:14.5px; color:#5a655f; margin:0;">Vue d'ensemble de la plateforme ANB.</p>
            </div>
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px;">
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#176B4D;">248</div><div style="font-size:13px; color:#5a655f;">Membres actifs</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#E97824;">12</div><div style="font-size:13px; color:#5a655f;">Nouvelles adhésions ce mois</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#176B4D;">3</div><div style="font-size:13px; color:#5a655f;">Événements à venir</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#E97824;">12</div><div style="font-size:13px; color:#5a655f;">Demandes à traiter</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#176B4D;">5</div><div style="font-size:13px; color:#5a655f;">Administrateurs actifs</div></div>
              <div style="background:#FFFFFF; border-radius:16px; padding:20px; box-shadow:0 8px 24px rgba(31,41,37,0.05);"><div style="font-size:22px; font-weight:800; color:#B14524;">2</div><div style="font-size:13px; color:#5a655f;">Alertes sécurité / maintenance</div></div>
            </div>

            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
              <h3 style="font-size:16.5px; font-weight:700; color:#1F2925; margin:0 0 16px;">Attention requise</h3>
              <div style="display:flex; flex-direction:column; gap:10px;" id="overview-attention-list">
                <!-- Dynamic -->
              </div>
            </div>

            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
              <h3 style="font-size:16.5px; font-weight:700; color:#1F2925; margin:0 0 16px;">Activité récente</h3>
              <div style="display:flex; flex-direction:column; gap:14px;" id="overview-activity-list">
                <!-- Dynamic -->
              </div>
            </div>
          </div>
        </section>

        <!-- UTILISATEURS ET ROLES VIEW -->
        <section id="view-users" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <div style="display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:14px;">
              <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Utilisateurs et rôles</h1>
              <button id="toggle-invite-btn" style="background:#E97824; color:#FFFFFF; border:none; padding:12px 22px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Inviter un utilisateur</button>
            </div>

            <div id="invite-user-box" class="hidden" style="background:#FFFFFF; border-radius:20px; padding:24px; box-shadow:0 8px 24px rgba(31,41,37,0.05); display:flex; flex-direction:column; gap:14px; max-width:520px;">
              <h3 style="font-size:16px; font-weight:700; color:#1F2925; margin:0;">Inviter un utilisateur</h3>
              <input id="invite-form-name" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px;" placeholder="Nom complet" />
              <input id="invite-form-email" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px;" placeholder="E-mail" />
              <select id="invite-form-role" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px; background: transparent;">
                <option>Admin</option>
                <option>Super Admin</option>
                <option>Éditeur / Bénévole</option>
              </select>
              <input id="invite-form-périmètre" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px;" placeholder="Périmètre d'accès (ex : Actualités, Événements)" />
              <textarea id="invite-form-msg" rows="2" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:14px; resize:vertical;" placeholder="Message d'invitation (facultatif)"></textarea>
              <button id="invite-user-submit-btn" style="align-self:flex-start; background:#176B4D; color:#FFFFFF; border:none; padding:12px 22px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Envoyer l'invitation</button>
              <div id="invite-success-alert" class="hidden" style="background:rgba(23,107,77,0.08); color:#176B4D; padding:12px 16px; border-radius:10px; font-size:13px; font-weight:700;">✓ Invitation envoyée.</div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; align-items:start; flex-wrap:wrap;">
              <div style="background:#FFFFFF; border-radius:20px; padding:8px; box-shadow:0 8px 24px rgba(31,41,37,0.05); min-width:0;" id="users-list-container">
                <!-- Dynamic -->
              </div>

              <div style="background:#FFFFFF; border-radius:20px; padding:24px; box-shadow:0 8px 24px rgba(31,41,37,0.05); min-width:0;" id="user-detail-box">
                <!-- Dynamic -->
              </div>
            </div>

            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05); overflow-x:auto;">
              <h3 style="font-size:16px; font-weight:700; color:#1F2925; margin:0 0 18px;">Matrice de permissions</h3>
              <div style="min-width:560px;">
                <div style="display:grid; grid-template-columns:1.6fr 1fr 1fr 1fr; gap:8px; padding-bottom:10px; border-bottom:2px solid rgba(31,41,37,0.08); margin-bottom:8px;">
                  <div></div>
                  <div style="font-size:12.5px; font-weight:700; color:#176B4D; text-align:center;">Super Admin</div>
                  <div style="font-size:12.5px; font-weight:700; color:#E97824; text-align:center;">Admin</div>
                  <div style="font-size:12.5px; font-weight:700; color:#5a655f; text-align:center;">Éditeur</div>
                </div>
                <div id="permission-matrix-rows">
                  <!-- Dynamic -->
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- CONTENUS ET VALIDATIONS VIEW -->
        <section id="view-contenus" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Contenus et validations</h1>
            <div style="display:grid; grid-template-columns:1fr 1.2fr; gap:20px; align-items:start; flex-wrap:wrap;">
              <div style="background:#FFFFFF; border-radius:20px; padding:8px; box-shadow:0 8px 24px rgba(31,41,37,0.05); min-width:0;" id="validations-queue-list">
                <!-- Dynamic -->
              </div>
              <div style="background:#FFFFFF; border-radius:20px; padding:24px; box-shadow:0 8px 24px rgba(31,41,37,0.05); min-width:0;" id="validation-detail-box">
                <!-- Dynamic -->
              </div>
            </div>
          </div>
        </section>

        <!-- DONNEES ET EXPORTS VIEW -->
        <section id="view-donnees" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Données et exports</h1>
            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05);">
              <h3 style="font-size:15.5px; font-weight:700; color:#1F2925; margin:0 0 16px;">Générer un export sécurisé</h3>
              <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:16px;">
                <label style="display:flex; align-items:center; gap:10px; font-size:13.5px; color:#1F2925;"><input type="checkbox" checked />Demandes d'adhésion</label>
                <label style="display:flex; align-items:center; gap:10px; font-size:13.5px; color:#1F2925;"><input type="checkbox" checked />Inscriptions aux événements</label>
                <label style="display:flex; align-items:center; gap:10px; font-size:13.5px; color:#1F2925;"><input type="checkbox" />Messages de contact</label>
                <label style="display:flex; align-items:center; gap:10px; font-size:13.5px; color:#1F2925;"><input type="checkbox" />Newsletter</label>
              </div>
              <div style="display:flex; gap:14px; flex-wrap:wrap; margin-bottom:16px;">
                <select style="flex:1; min-width:180px; padding:11px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:13.5px; background: transparent;">
                  <option>30 derniers jours</option>
                  <option>3 derniers mois</option>
                  <option>Cette année</option>
                </select>
                <input id="export-reason" style="flex:2; min-width:220px; padding:11px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:13.5px;" placeholder="Raison de l'export (obligatoire)" />
              </div>
              <button id="generate-export-btn" style="background:#E97824; color:#FFFFFF; border:none; padding:12px 24px; border-radius:999px; font-weight:700; font-size:14px; cursor:pointer;">Générer l'export sécurisé</button>
              
              <div id="export-confirm-box" class="hidden" style="margin-top:16px; background:#F8F4EC; border-radius:14px; padding:18px; display:flex; flex-direction:column; gap:10px;">
                <div style="font-size:13.5px; color:#1F2925; font-weight:600;">Confirmez-vous cet export ? Il sera tracé dans le journal d'activité et limité aux champs strictement nécessaires.</div>
                <div style="display:flex; gap:10px;">
                  <button id="confirm-export-action" style="background:#176B4D; color:#FFFFFF; border:none; padding:10px 20px; border-radius:999px; font-weight:700; font-size:13px; cursor:pointer;">Confirmer l'export</button>
                  <button id="cancel-export-action" style="background:#FFFFFF; color:#1F2925; border:1px solid rgba(31,41,37,0.15); padding:10px 20px; border-radius:999px; font-weight:700; font-size:13px; cursor:pointer;">Annuler</button>
                </div>
              </div>
              <div id="export-success-alert" class="hidden" style="margin-top:16px; background:rgba(23,107,77,0.08); color:#176B4D; padding:12px 16px; border-radius:10px; font-size:13px; font-weight:700;">✓ Export généré et tracé dans le journal d'activité.</div>
            </div>

            <div style="background:#FFFFFF; border-radius:20px; padding:26px; box-shadow:0 8px 24px rgba(31,41,37,0.05); overflow-x:auto;">
              <h3 style="font-size:15.5px; font-weight:700; color:#1F2925; margin:0 0 16px;">Demandes liées aux données personnelles</h3>
              <div style="min-width:560px;" id="personal-data-requests-container">
                <!-- personal data requests lists -->
              </div>
            </div>
          </div>
        </section>

        <!-- JOURNAL D'ACTIVITE VIEW -->
        <section id="view-journal" class="hidden fade-in">
          <div style="display:flex; flex-direction:column; gap:20px;">
            <h1 style="font-size:22px; font-weight:800; color:#1F2925; margin:0;">Journal d'activité</h1>
            <p style="font-size:13px; color:#5a655f; margin:0;">Journal en lecture seule — chaque action sensible y est enregistrée automatiquement.</p>
            <div style="display:flex; gap:8px; flex-wrap:wrap;" class="journal-tab-container">
              <!-- User filters tabs -->
            </div>
            <div style="background:#FFFFFF; border-radius:20px; padding:8px; box-shadow:0 8px 24px rgba(31,41,37,0.05);" id="journal-list-container">
              <!-- Logs items -->
            </div>
          </div>
