          state.validationSelectedIdx = i;
          renderValidations();
        });
        listWrapper.appendChild(item);
      });

      const detailBox = document.getElementById('validation-detail-box');
      const selected = validationQueue[state.validationSelectedIdx] || validationQueue[0];

      if (!selected) {
        detailBox.innerHTML = '';
        return;
      }

      detailBox.innerHTML = `
        <h3 style="font-size:16px; font-weight:700; color:#1F2925; margin:0 0 6px;">${selected.title}</h3>
        <div style="font-size:13px; color:#5a655f; margin-bottom:16px;">Par ${selected.author} · ${selected.date}</div>
        <div style="aspect-ratio:16/9; border-radius:14px; background:linear-gradient(150deg,#E8D8BF,#176B4D); margin-bottom:18px;"></div>
        <div style="font-size:13px; font-weight:700; color:#1F2925; margin-bottom:8px;">Commentaire pour l'auteur</div>
        <textarea id="validation-comment-text" rows="2" style="width:100%; padding:12px 14px; border-radius:10px; border:1.5px solid #e3dccb; font-size:13.5px; resize:vertical; margin-bottom:16px;" placeholder="Optionnel..."></textarea>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <button id="validation-approve-btn" style="background:#176B4D; color:#FFFFFF; border:none; padding:11px 20px; border-radius:999px; font-weight:700; font-size:13.5px; cursor:pointer;">Approuver et publier</button>
          <button id="validation-return-btn" style="background:#F8F4EC; color:#1F2925; border:none; padding:11px 20px; border-radius:999px; font-weight:700; font-size:13.5px; cursor:pointer;">Renvoyer avec commentaire</button>
        </div>
      `;

      document.getElementById('validation-approve-btn').addEventListener('click', () => {
        validationQueue.splice(state.validationSelectedIdx, 1);
        state.validationSelectedIdx = 0;
        logActivity('Nasser', 'Super Admin', 'Validation de contenu', selected.title);
        alert(`Le contenu "${selected.title}" a été approuvé et publié !`);
        renderValidations();
      });

      document.getElementById('validation-return-btn').addEventListener('click', () => {
        const comment = document.getElementById('validation-comment-text').value.trim() || 'Des ajustements sont requis.';
        selected.status = 'Renvoyé avec commentaire';
        logActivity('Nasser', 'Super Admin', 'Retour de contenu', `${selected.title} : ${comment}`);
        alert(`Le contenu a été renvoyé avec votre commentaire.`);
        renderValidations();
      });
    }

    // 4. Données
    function renderDonnees() {
      const wrapper = document.getElementById('personal-data-requests-container');
      wrapper.innerHTML = '';
      
      dataRequests.forEach(r => {
        const row = document.createElement('div');
        row.style.cssText = 'display:flex; align-items:center; gap:16px; padding:14px 0; border-bottom:1px solid rgba(31,41,37,0.06); flex-wrap:wrap;';
        row.innerHTML = `
          <div style="flex:1; min-width:180px; font-size:14px; font-weight:700; color:#1F2925;">${r.type}</div>
          <div style="min-width:140px; font-size:13px; color:#5a655f;">${r.requester}</div>
          ${getBadgeHtml(r.status, r.tone)}
          <div style="min-width:140px; font-size:13px; color:#5a655f;">Resp. : ${r.responsable}</div>
          <div style="min-width:140px; font-size:13px; color:#5a655f;">Échéance : ${r.deadline}</div>
        `;
        wrapper.appendChild(row);
      });
    }

    const generateExportBtn = document.getElementById('generate-export-btn');
    const exportConfirmBox = document.getElementById('export-confirm-box');
    const exportSuccessAlert = document.getElementById('export-success-alert');

    generateExportBtn.addEventListener('click', () => {
      const reason = document.getElementById('export-reason').value.trim();
      if (!reason) {
        alert('Veuillez entrer une raison de sécurité pour justifier cet export.');
        return;
      }
      exportConfirmBox.classList.remove('hidden');
      exportSuccessAlert.classList.add('hidden');
    });

    document.getElementById('confirm-export-action').addEventListener('click', () => {
      const reason = document.getElementById('export-reason').value.trim();
      exportConfirmBox.classList.add('hidden');
      exportSuccessAlert.classList.remove('hidden');
      logActivity('Nasser', 'Super Admin', 'Export de données sécurisé', reason);
      setTimeout(() => {
        exportSuccessAlert.classList.add('hidden');
        document.getElementById('export-reason').value = '';
      }, 2000);
    });

    document.getElementById('cancel-export-action').addEventListener('click', () => {
      exportConfirmBox.classList.add('hidden');
    });

    // 5. Journal
    function renderJournal() {
      const tabsWrapper = document.querySelector('.journal-tab-container');
      tabsWrapper.innerHTML = '';
      const filters = ['Tous', 'Mariama', 'Nasser', 'Fatou'];

      filters.forEach(f => {
        const btn = document.createElement('button');
        btn.style.cssText = `border:2px solid #176B4D; padding:9px 18px; border-radius:999px; font-weight:700; font-size:13.5px; cursor:pointer;`;
        if (state.journalUserFilter === f) {
          btn.style.background = '#176B4D';
          btn.style.color = '#FFFFFF';
        } else {
          btn.style.background = 'transparent';
          btn.style.color = '#176B4D';
        }
        btn.textContent = f;
        btn.addEventListener('click', () => {
          state.journalUserFilter = f;
          renderJournal();
        });
        tabsWrapper.appendChild(btn);
      });

      const container = document.getElementById('journal-list-container');
      container.innerHTML = '';

      const filtered = state.journalUserFilter === 'Tous' ? journalLogs : journalLogs.filter(j => j.user === state.journalUserFilter);

      filtered.forEach(j => {
        const row = document.createElement('div');
        row.style.cssText = 'display:flex; gap:16px; padding:16px; border-bottom:1px solid rgba(31,41,37,0.06); flex-wrap:wrap; font-size: 13.5px;';
        row.innerHTML = `
          <div style="min-width:170px; color:#5a655f;">${j.date}</div>
          <div style="min-width:110px; font-weight:700; color:#1F2925;">${j.user}</div>
          <div style="min-width:120px;">${getBadgeHtml(j.role, j.roleT)}</div>
          <div style="flex:1; min-width:220px; color:#1F2925;"><strong>${j.action}</strong> — <span style="color:#5a655f;">${j.detail}</span></div>
          <div style="font-size:11.5px; color:#9aa39c;">IP ${j.ip}</div>
        `;
        container.appendChild(row);
      });
    }

    // 6. Intégrations
    function renderIntegrations() {
      const container = document.getElementById('integrations-list-container');
      container.innerHTML = '';

      integrations.forEach(i => {
        const card = document.createElement('div');
        card.style.cssText = 'background:#FFFFFF; border-radius:18px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05); display: flex; flex-direction: column; justify-content: space-between;';
        card.innerHTML = `
          <div>
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; gap: 8px;">
              <h3 style="font-size:15px; font-weight:700; color:#1F2925; margin:0;">${i.name}</h3>
              ${getBadgeHtml(i.status, i.tone)}
            </div>
            <p style="font-size:13px; color:#5a655f; line-height:1.5; margin:0 0 12px;">${i.desc}</p>
            <div style="font-size:11.5px; color:#9aa39c; margin-bottom:14px;">Synchro : ${i.sync}</div>
          </div>
          <button style="background:#F8F4EC; color:#1F2925; border:none; padding:9px 18px; border-radius:999px; font-weight:700; font-size:12.5px; cursor:pointer;" onclick="alert('Configuration integration : ${i.name}')">${i.actionLabel}</button>
        `;
        container.appendChild(card);
      });
    }

    // 7. Sécurité
    function renderSecurite() {
      const toggleBtn = document.getElementById('twofa-toggle-btn');
      const indicator = document.getElementById('twofa-toggle-indicator');
      const statusLabel = document.getElementById('twofa-status-label');

      const update2FA = () => {
        if (state.twoFA) {
          toggleBtn.style.background = '#176B4D';
          indicator.style.left = '23px';
          statusLabel.textContent = 'Activée pour votre compte.';
        } else {
          toggleBtn.style.background = '#d8d0c0';
          indicator.style.left = '3px';
          statusLabel.textContent = 'Désactivée — activation recommandée.';
        }
      };

      toggleBtn.replaceWith(toggleBtn.cloneNode(true));
      document.getElementById('twofa-toggle-btn').addEventListener('click', () => {
        state.twoFA = !state.twoFA;
        update2FA();
        logActivity('Nasser', 'Super Admin', 'Sécurité 2FA modifiée', state.twoFA ? '2FA Activée' : '2FA Désactivée');
      });

      update2FA();

      const list = document.getElementById('active-sessions-list');
      list.innerHTML = '';
      const sessions = [
        { device: 'Chrome — Windows (Garba)', location: 'Bordeaux, France', time: 'Session active' },
        { device: 'Safari — iPhone', location: 'Bordeaux, France', time: 'Il y a 1 heure' },
        { device: 'Chrome — Windows (Test)', location: 'Paris, France', time: 'Il y a 2 jours' }
      ];

      sessions.forEach(s => {
        const item = document.createElement('div');
        item.style.cssText = 'display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid rgba(31,41,37,0.06); font-size:13.5px; flex-wrap:wrap; gap:8px;';
        item.innerHTML = `
          <span style="color:#1F2925; font-weight:600;">${s.device}</span>
          <span style="color:#5a655f;">${s.location}</span>
          <span style="color:#9aa39c;">${s.time}</span>
        `;
        list.appendChild(item);
      });

      document.getElementById('disconnect-all-btn').onclick = () => {
        alert('Toutes les autres sessions ont été déconnectées.');
        logActivity('Nasser', 'Super Admin', 'Déconnexion sessions actives', 'Toutes sessions tierces révoquées');
      };
    }

    // 8. Sauvegardes
    function renderSauvegardes() {
      const historyList = document.getElementById('backup-history-list');
      historyList.innerHTML = '';

      backupHistory.forEach(b => {
        const row = document.createElement('div');
        row.style.cssText = 'display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid rgba(31,41,37,0.06); font-size:13.5px; flex-wrap:wrap; gap:8px;';
        row.innerHTML = `
          <span style="color:#1F2925;">${b.date}</span>
          ${getBadgeHtml(b.status, b.tone)}
          <span style="color:#9aa39c;">${b.size}</span>
        `;
        historyList.appendChild(row);
      });
    }

    const runBackupBtn = document.getElementById('run-backup-btn');
    const backupAlert = document.getElementById('backup-running-alert');
    runBackupBtn.addEventListener('click', () => {
      backupAlert.classList.remove('hidden');
      const date = new Date();
      const pad = (n) => String(n).padStart(2, '0');
      const dateStr = `${date.getDate()} juillet 2026, ${pad(date.getHours())}:${pad(date.getMinutes())}`;
      
      backupHistory.unshift({
        date: dateStr,
        status: 'Réussie',
        tone: 'g',
        size: '483 Mo'
      });

      logActivity('Nasser', 'Super Admin', 'Lancement de sauvegarde', 'Sauvegarde manuelle du système');

      setTimeout(() => {
        backupAlert.classList.add('hidden');
        renderSauvegardes();
      }, 1500);
    });

    const openRestoreBtn = document.getElementById('open-restore-btn');
    const restoreBox = document.getElementById('restore-confirm-box');

    openRestoreBtn.addEventListener('click', () => {
      restoreBox.classList.remove('hidden');
    });
    document.getElementById('cancel-restore-action').addEventListener('click', () => {
      restoreBox.classList.add('hidden');
    });
    document.getElementById('confirm-restore-action').addEventListener('click', () => {
      restoreBox.classList.add('hidden');
      alert('Restauration système complétée.');
      logActivity('Nasser', 'Super Admin', 'Restauration système', 'Restauration effectuée avec succès');
      renderSauvegardes();
    });

    // 9. Mentions
    function renderMentions() {
      const container = document.getElementById('legal-sections-container');
      container.innerHTML = '';

      legalSections.forEach(ls => {
        const item = document.createElement('div');
        item.style.cssText = 'background:#FFFFFF; border-radius:18px; padding:22px; box-shadow:0 8px 24px rgba(31,41,37,0.05); display: flex; justify-content: space-between; align-items: center; gap: 14px;';
        item.innerHTML = `
          <div>
            <h3 style="font-size:15px; font-weight:700; color:#1F2925; margin:0 0 6px;">${ls.title}</h3>
            <div style="font-size:12.5px; color:#9aa39c;">Dernière modification : ${ls.updated}</div>
          </div>
          <button style="background:#F8F4EC; color:#1F2925; border:none; padding:8px 16px; border-radius:999px; font-weight:700; font-size:12.5px; cursor:pointer;" onclick="alert('Modifier : ${ls.title}')">Modifier</button>
        `;
        container.appendChild(item);
      });
    }

    // 10. Statistiques
    function renderStats() {
      const periodsWrapper = document.querySelector('.stats-period-container');
      periodsWrapper.innerHTML = '';
      const periodDefs = ['7 jours', '30 jours', '3 mois', '1 an'];

      periodDefs.forEach(p => {
        const btn = document.createElement('button');
        btn.style.cssText = `border:2px solid #176B4D; padding:8px 16px; border-radius:999px; font-weight:700; font-size:13px; cursor:pointer;`;
        if (state.statsPeriod === p) {
          btn.style.background = '#176B4D';
          btn.style.color = '#FFFFFF';
        } else {
          btn.style.background = 'transparent';
          btn.style.color = '#176B4D';
        }
        btn.textContent = p;
        btn.addEventListener('click', () => {
          state.statsPeriod = p;
          renderStats();
        });
        periodsWrapper.appendChild(btn);
      });

      const barsWrapper = document.getElementById('visit-bars-container');
      barsWrapper.innerHTML = '';
      const visitHeights = {
        '7 jours': [45, 60, 50, 75, 60, 90, 70],
        '30 jours': [65, 80, 55, 90, 75, 100, 85],
        '3 mois': [50, 55, 45, 70, 65, 80, 75],
        '1 an': [30, 45, 40, 60, 50, 75, 65]
      };
      
      const heights = visitHeights[state.statsPeriod] || visitHeights['30 jours'];
      const days = ['L','M','M','J','V','S','D'];

      heights.forEach((h, idx) => {
        const barCol = document.createElement('div');
        barCol.style.cssText = 'flex:1; display:flex; flex-direction:column; align-items:center; gap:8px; height:100%; justify-content:flex-end;';
        barCol.innerHTML = `
          <div style="width:100%; max-width:32px; height:${h}%; background:#176B4D; border-radius:8px 8px 0 0; transition: height 0.3s ease;"></div>
          <span style="font-size:11px; color:#9aa39c;">${days[idx]}</span>
        `;
        barsWrapper.appendChild(barCol);
      });

      const pagesList = document.getElementById('top-pages-list');
      pagesList.innerHTML = '';
      const pData = [
        { name: 'Accueil', views: state.statsPeriod === '7 jours' ? '410' : '2 140' },
        { name: 'Événements', views: state.statsPeriod === '7 jours' ? '180' : '980' },
        { name: "L'association", views: state.statsPeriod === '7 jours' ? '120' : '640' },
        { name: 'Culture nigérienne', views: state.statsPeriod === '7 jours' ? '82' : '410' }
      ];
      pData.forEach(tp => {
        const item = document.createElement('div');
        item.style.cssText = 'display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid rgba(31,41,37,0.06); font-size:13.5px;';
        item.innerHTML = `<span style="color:#1F2925;">${tp.name}</span><span style="font-weight:700; color:#176B4D;">${tp.views}</span>`;
        pagesList.appendChild(item);
      });

      const articlesList = document.getElementById('top-articles-list');
      articlesList.innerHTML = '';
      const aData = [
        { name: 'Retour sur notre rencontre', views: state.statsPeriod === '7 jours' ? '92' : '520' },
        { name: 'Bienvenue aux membres', views: state.statsPeriod === '7 jours' ? '70' : '380' },
        { name: 'Appel à bénévoles', views: state.statsPeriod === '7 jours' ? '54' : '310' }
      ];
      aData.forEach(ta => {
        const item = document.createElement('div');
        item.style.cssText = 'display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid rgba(31,41,37,0.06); font-size:13.5px;';
        item.innerHTML = `<span style="color:#1F2925;">${ta.name}</span><span style="font-weight:700; color:#176B4D;">${ta.views}</span>`;
        articlesList.appendChild(item);
      });
    }
  </script>

</body>
</html>
