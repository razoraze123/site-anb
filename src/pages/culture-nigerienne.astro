---
import Layout from '../layouts/Layout.astro';

const entries = [
  {
    titre: "Langues",
    texte: "Le français est la langue officielle, aux côtés de langues nationales comme le haoussa, le zarma, le tamasheq, le peul, le kanouri et bien d'autres, parlées avec fierté au quotidien.",
    gradient: "linear-gradient(150deg,#E8D8BF,#E97824)",
    accent: "#E97824",
    icon: `<path d="M4 5h16v10H9l-4 4V5z"/><line x1="7" y1="8" x2="17" y2="8"/><line x1="7" y1="12" x2="14" y2="12"/>`
  },
  {
    titre: "Traditions et fêtes",
    texte: "Cérémonies, mariages, fêtes religieuses et rites de passage rythment la vie sociale nigérienne, célébrés avec musique, habits traditionnels et générosité.",
    gradient: "linear-gradient(150deg,#176B4D,#E8D8BF)",
    accent: "#176B4D",
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.9 4.9l2.8 2.8M16.3 16.3l2.8 2.8M2 12h4M18 12h4M4.9 19.1l2.8-2.8M16.3 7.7l2.8-2.8"/>`
  },
  {
    titre: "Gastronomie",
    texte: "Riz au gras, tô, sauces d'arachide ou de gombo, brochettes et thé partagé : la cuisine nigérienne est faite pour être partagée en communauté.",
    gradient: "linear-gradient(150deg,#E97824,#1F2925)",
    accent: "#E97824",
    icon: `<path d="M4 12h16a8 8 0 01-16 0z"/><path d="M9 12V9M12 12V7M15 12V9"/>`
  },
  {
    titre: "Musique et danse",
    texte: "Du takamba touareg aux rythmes haoussa, la musique nigérienne accompagne chaque grand moment de la vie communautaire.",
    gradient: "linear-gradient(150deg,#E8D8BF,#176B4D)",
    accent: "#176B4D",
    icon: `<path d="M9 18V5l10-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="16" cy="16" r="3"/>`
  },
  {
    titre: "Artisanat",
    texte: "Maroquinerie touareg, poteries, tissages et bijoux témoignent d'un savoir-faire transmis de génération en génération.",
    gradient: "linear-gradient(150deg,#1F2925,#E97824)",
    accent: "#E97824",
    icon: `<path d="M12 3l9 9-9 9-9-9z"/><path d="M12 8l4 4-4 4-4-4z"/>`
  }
];

const peuples = [
  { nom: "Haoussa", x: 78, y: 30 },
  { nom: "Zarma-Songhaï", x: 22, y: 42 },
  { nom: "Touareg", x: 35, y: 12 },
  { nom: "Peul", x: 70, y: 72 },
  { nom: "Kanouri", x: 24, y: 78 }
];
---

<Layout title="Culture nigérienne" description="Langues, traditions, gastronomie, musique et artisanat : un aperçu de la richesse culturelle du Niger.">
  <main>
    <section style="max-width:1280px; margin:0 auto; padding:70px clamp(20px,4vw,48px) 20px;">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
        <span style="display:flex; gap:3px;">
          <span style="width:5px; height:16px; border-radius:2px; background:#E97824;"></span>
          <span style="width:5px; height:16px; border-radius:2px; background:#E8D8BF;"></span>
          <span style="width:5px; height:16px; border-radius:2px; background:#176B4D;"></span>
        </span>
        <span style="font-size:13px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#5a655f;">Culture nigérienne</span>
      </div>
      <h1 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(2.1rem,4vw,3.2rem); color:#1F2925; margin:0 0 24px; max-width:760px;">Nos racines, notre richesse, notre fierté.</h1>
      <p style="font-size:18px; line-height:1.75; color:#3f4a45; max-width:680px; margin:0 0 60px;">Le Niger est un pays de diversité et de traditions vivantes. À travers cette page, nous partageons un aperçu de nos langues, nos fêtes, notre gastronomie et nos arts.</p>
    </section>

    <section data-band data-reveal style="background:linear-gradient(120deg,#176B4D,#1F2925); padding:70px 0;">
      <div style="max-width:1280px; margin:0 auto; padding:0 clamp(20px,4vw,48px); display:flex; flex-wrap:wrap; gap:44px; align-items:center;">
        <div style="flex:1 1 380px; min-width:260px; aspect-ratio:16/11; position:relative;">
          <svg viewBox="0 0 100 100" style="width:100%; height:100%;">
            <circle cx="50" cy="50" r="15" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="0.6" stroke-dasharray="1.5 2.5"/>
            {peuples.map((p) => (
              <line x1="50" y1="50" x2={p.x} y2={p.y} stroke="rgba(255,255,255,0.35)" stroke-width="0.6"/>
            ))}
            <circle cx="50" cy="50" r="5" fill="#E97824"/>
            <text x="50" y="51.5" text-anchor="middle" font-size="2.6" font-weight="700" fill="#FFFFFF">NIGER</text>
            {peuples.map((p) => (
              <g>
                <circle cx={p.x} cy={p.y} r="2.6" fill="#F8F4EC"/>
                <text
                  x={p.x}
                  y={p.y + (p.y > 50 ? 6 : -4.5)}
                  text-anchor="middle"
                  font-size="3"
                  font-weight="700"
                  fill="#F8F4EC"
                  opacity="0.9"
                >{p.nom}</text>
              </g>
            ))}
          </svg>
        </div>
        <div style="flex:1 1 380px; min-width:260px; color:#FFFFFF;">
          <h2 style="font-family:'Unbounded',sans-serif; font-size:clamp(1.5rem,2.4vw,2rem); font-weight:700; margin:0 0 16px;">Le Niger</h2>
          <p style="font-size:15.5px; line-height:1.75; opacity:0.9; margin:0;">Un pays sahélien au cœur de l'Afrique de l'Ouest, riche de la diversité de ses peuples — Haoussa, Zarma-Songhaï, Touareg, Peul, Kanouri et bien d'autres — unis par une histoire et des traditions partagées.</p>
        </div>
      </div>
    </section>

    <section style="max-width:1280px; margin:0 auto; padding:80px clamp(20px,4vw,48px); display:flex; flex-direction:column; gap:70px;">
      {entries.map((e, i) => (
        <div data-reveal class="culture-row" style={`flex-direction:${i % 2 === 1 ? 'row-reverse' : 'row'};`}>
          <div style="flex:1 1 380px; min-width:260px;">
            <div style={`width:44px; height:44px; border-radius:12px; background:${e.accent}1a; display:flex; align-items:center; justify-content:center; margin-bottom:16px;`}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={e.accent} stroke-width="1.6" set:html={e.icon} />
            </div>
            <h2 style="font-family:'Unbounded',sans-serif; font-size:clamp(1.4rem,2.2vw,1.8rem); font-weight:700; color:#1F2925; margin:0 0 16px;">{e.titre}</h2>
            <p style="font-size:15.5px; line-height:1.75; color:#3f4a45; margin:0;">{e.texte}</p>
          </div>
          <div class="culture-swatch" style={`flex:1 1 300px; min-width:220px; aspect-ratio:4/3; background:${e.gradient};`}>
            <svg width="88" height="88" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.28" set:html={e.icon} />
          </div>
        </div>
      ))}
    </section>
  </main>

  <style>
    .culture-row {
      display: flex;
      flex-wrap: wrap;
      gap: 44px;
      align-items: center;
    }
    .culture-swatch {
      border-radius: 22px;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .culture-swatch::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0.5;
      background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.08) 0px, rgba(255,255,255,0.08) 2px, transparent 2px, transparent 22px),
                        repeating-linear-gradient(-45deg, rgba(255,255,255,0.08) 0px, rgba(255,255,255,0.08) 2px, transparent 2px, transparent 22px);
    }
  </style>
</Layout>
