---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vie pratique" description="Des repères simples et concrets pour bien s'installer à Bordeaux : études, logement, travail, santé, démarches.">
  <main>
    <section style="max-width:1280px; margin:0 auto; padding:70px clamp(20px,4vw,48px) 90px;">
      <div style="font-size:13px; font-weight:700; color:#E97824; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;">Vie pratique</div>
      <h1 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(2.1rem,4vw,3rem); color:#1F2925; margin:0 0 20px; max-width:760px;">Tout ce qu'il faut savoir pour bien s'installer à Bordeaux.</h1>
      <p style="font-size:17px; line-height:1.7; color:#3f4a45; max-width:680px; margin:0 0 56px;">Des repères simples et concrets pour avancer sereinement dans vos démarches, vos études, votre logement et votre quotidien.</p>

      <div data-grid-mobile="2" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:24px;">
        <div style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.6" style="margin-bottom:18px;"><path d="M22 10L12 5 2 10l10 5 10-5z"></path><path d="M6 12.5V17c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5"></path></svg>
          <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">Étudier</h3>
          <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0;">Inscriptions universitaires, bourses, CROUS, tutorat et vie de campus à Bordeaux.</p>
        </div>
        <div style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.6" style="margin-bottom:18px;"><path d="M4 11l8-7 8 7"></path><path d="M6 10v9a1 1 0 001 1h10a1 1 0 001-1v-9"></path></svg>
          <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">Se loger</h3>
          <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0;">Recherche de logement, garanties, colocation et quartiers accueillants.</p>
        </div>
        <div style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.6" style="margin-bottom:18px;"><rect x="3" y="7" width="18" height="13" rx="2"></rect><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"></path></svg>
          <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">Travailler</h3>
          <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0;">Recherche d'emploi, alternance, autorisation de travail et réseau professionnel.</p>
        </div>
        <div style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.6" style="margin-bottom:18px;"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v10M7 12h10"></path></svg>
          <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">Santé</h3>
          <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0;">Sécurité sociale, mutuelle, médecins et centres de soins accessibles.</p>
        </div>
        <div style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.6" style="margin-bottom:18px;"><rect x="5" y="3" width="14" height="18" rx="2"></rect><line x1="8.5" y1="8" x2="15.5" y2="8"></line><line x1="8.5" y1="12" x2="15.5" y2="12"></line><line x1="8.5" y1="16" x2="12.5" y2="16"></line></svg>
          <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">Démarches</h3>
          <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0;">Titre de séjour, préfecture, banque et administration au quotidien.</p>
        </div>
        <div style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.6" style="margin-bottom:18px;"><path d="M6 3a2 2 0 00-2 2c0 9 7 16 16 16a2 2 0 002-2v-2.5a1 1 0 00-.8-1L17 14.2a1 1 0 00-1 .25l-1.3 1.3a12 12 0 01-5.4-5.4l1.3-1.3a1 1 0 00.25-1L9.5 3.8a1 1 0 00-1-.8H6z"></path></svg>
          <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">Contacts utiles</h3>
          <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0;">Numéros et adresses utiles pour toutes vos démarches à Bordeaux.</p>
        </div>
      </div>
    </section>
  </main>
</Layout>
