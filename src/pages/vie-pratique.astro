---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    href: "/vie-pratique/etudier",
    couleur: "#176B4D",
    titre: "Étudier",
    description: "Inscriptions universitaires, bourses, CROUS, tutorat et vie de campus à Bordeaux.",
    svg: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.6"><path d="M22 10L12 5 2 10l10 5 10-5z"/><path d="M6 12.5V17c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5"/></svg>`
  },
  {
    href: "/vie-pratique/se-loger",
    couleur: "#E97824",
    titre: "Se loger",
    description: "Recherche de logement, garanties, colocation et quartiers accueillants.",
    svg: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.6"><path d="M4 11l8-7 8 7"/><path d="M6 10v9a1 1 0 001 1h10a1 1 0 001-1v-9"/></svg>`
  },
  {
    href: "/vie-pratique/travailler",
    couleur: "#176B4D",
    titre: "Travailler",
    description: "Recherche d'emploi, alternance, autorisation de travail et réseau professionnel.",
    svg: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.6"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>`
  },
  {
    href: "/vie-pratique/sante",
    couleur: "#E97824",
    titre: "Santé",
    description: "Sécurité sociale, mutuelle, médecins et centres de soins accessibles.",
    svg: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M7 12h10"/></svg>`
  },
  {
    href: "/vie-pratique/demarches",
    couleur: "#176B4D",
    titre: "Démarches",
    description: "Titre de séjour, préfecture, banque et administration au quotidien.",
    svg: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.6"><rect x="5" y="3" width="14" height="18" rx="2"/><line x1="8.5" y1="8" x2="15.5" y2="8"/><line x1="8.5" y1="12" x2="15.5" y2="12"/><line x1="8.5" y1="16" x2="12.5" y2="16"/></svg>`
  },
  {
    href: "/vie-pratique/contacts-utiles",
    couleur: "#E97824",
    titre: "Contacts utiles",
    description: "Numéros et adresses utiles pour toutes vos démarches à Bordeaux.",
    svg: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.6"><path d="M6 3a2 2 0 00-2 2c0 9 7 16 16 16a2 2 0 002-2v-2.5a1 1 0 00-.8-1L17 14.2a1 1 0 00-1 .25l-1.3 1.3a12 12 0 01-5.4-5.4l1.3-1.3a1 1 0 00.25-1L9.5 3.8a1 1 0 00-1-.8H6z"/></svg>`
  }
];
---

<Layout title="Vie pratique" description="Des repères simples et concrets pour bien s'installer à Bordeaux : études, logement, travail, santé, démarches.">
  <main>
    <section style="max-width:1280px; margin:0 auto; padding:70px clamp(20px,4vw,48px) 90px;">
      <div style="font-size:13px; font-weight:700; color:#E97824; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;">Vie pratique</div>
      <h1 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(2.1rem,4vw,3rem); color:#1F2925; margin:0 0 20px; max-width:760px;">Tout ce qu'il faut savoir pour bien s'installer à Bordeaux.</h1>
      <p style="font-size:17px; line-height:1.7; color:#3f4a45; max-width:680px; margin:0 0 56px;">Des repères simples et concrets pour avancer sereinement dans vos démarches, vos études, votre logement et votre quotidien.</p>

      <div data-reveal-group style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:24px;">
        {categories.map(cat => (
          <a href={cat.href} style="background:#FFFFFF; border-radius:24px; padding:32px; box-shadow:0 10px 26px rgba(31,41,37,0.06); text-decoration:none; display:block; transition:all 0.25s; border:1.5px solid transparent; position:relative; overflow:hidden; group;">
            <div style="margin-bottom:18px;" set:html={cat.svg} />
            <h3 style="font-size:18px; font-weight:700; color:#1F2925; margin:0 0 12px;">{cat.titre}</h3>
            <p style="font-size:14.5px; line-height:1.7; color:#5a655f; margin:0 0 16px;">{cat.description}</p>
            <span style={`display:inline-flex; align-items:center; gap:6px; font-size:13.5px; font-weight:700; color:${cat.couleur};`}>
              Découvrir
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  a[href^="/vie-pratique/"]:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(31,41,37,0.1) !important;
    border-color: rgba(31,41,37,0.08) !important;
  }
</style>
