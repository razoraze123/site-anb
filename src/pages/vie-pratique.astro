---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    href: "/vie-pratique/etudier",
    couleur: "#176B4D",
    titre: "Étudier",
    description: "Inscriptions universitaires, bourses, CROUS, tutorat et vie de campus à Bordeaux.",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1.6"><path d="M22 10L12 5 2 10l10 5 10-5z"/><path d="M6 12.5V17c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5"/></svg>`
  },
  {
    href: "/vie-pratique/se-loger",
    couleur: "#E97824",
    titre: "Se loger",
    description: "Recherche de logement, garanties, colocation et quartiers accueillants.",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1.6"><path d="M4 11l8-7 8 7"/><path d="M6 10v9a1 1 0 001 1h10a1 1 0 001-1v-9"/></svg>`
  },
  {
    href: "/vie-pratique/travailler",
    couleur: "#176B4D",
    titre: "Travailler",
    description: "Recherche d'emploi, alternance, autorisation de travail et réseau professionnel.",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1.6"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>`
  },
  {
    href: "/vie-pratique/sante",
    couleur: "#E97824",
    titre: "Santé",
    description: "Sécurité sociale, mutuelle, médecins et centres de soins accessibles.",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M7 12h10"/></svg>`
  },
  {
    href: "/vie-pratique/demarches",
    couleur: "#176B4D",
    titre: "Démarches",
    description: "Titre de séjour, préfecture, banque et administration au quotidien.",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1.6"><rect x="5" y="3" width="14" height="18" rx="2"/><line x1="8.5" y1="8" x2="15.5" y2="8"/><line x1="8.5" y1="12" x2="15.5" y2="12"/><line x1="8.5" y1="16" x2="12.5" y2="16"/></svg>`
  },
  {
    href: "/vie-pratique/contacts-utiles",
    couleur: "#E97824",
    titre: "Contacts utiles",
    description: "Numéros et adresses utiles pour toutes vos démarches à Bordeaux.",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="1.6"><path d="M6 3a2 2 0 00-2 2c0 9 7 16 16 16a2 2 0 002-2v-2.5a1 1 0 00-.8-1L17 14.2a1 1 0 00-1 .25l-1.3 1.3a12 12 0 01-5.4-5.4l1.3-1.3a1 1 0 00.25-1L9.5 3.8a1 1 0 00-1-.8H6z"/></svg>`
  }
];
---

<Layout title="Vie pratique" description="Des repères simples et concrets pour bien s'installer à Bordeaux : études, logement, travail, santé, démarches.">
  <main>
    <section style="max-width:1280px; margin:0 auto; padding:70px clamp(20px,4vw,48px) 90px;">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
        <span style="display:flex; gap:3px;">
          <span style="width:5px; height:16px; border-radius:2px; background:#E97824;"></span>
          <span style="width:5px; height:16px; border-radius:2px; background:#E8D8BF;"></span>
          <span style="width:5px; height:16px; border-radius:2px; background:#176B4D;"></span>
        </span>
        <span style="font-size:13px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#5a655f;">Vie pratique</span>
      </div>
      <h1 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(2.1rem,4vw,3rem); color:#1F2925; margin:0 0 20px; max-width:760px;">Tout ce qu'il faut savoir pour bien s'installer à Bordeaux.</h1>
      <p style="font-size:17px; line-height:1.7; color:#3f4a45; max-width:680px; margin:0 0 56px;">Des repères simples et concrets pour avancer sereinement dans vos démarches, vos études, votre logement et votre quotidien.</p>

      <div class="practical-grid" data-reveal-group>
        {categories.map(cat => (
          <a href={cat.href} class="practical-tile" style={`background:${cat.couleur};`}>
            <div class="practical-icon" set:html={cat.svg} />
            <h3 style="font-size:18.5px; font-weight:800; color:#FFFFFF; margin:0 0 10px;">{cat.titre}</h3>
            <p style="font-size:14.5px; line-height:1.65; color:rgba(255,255,255,0.85); margin:0 0 18px;">{cat.description}</p>
            <span style="display:inline-flex; align-items:center; gap:6px; font-size:13.5px; font-weight:700; color:#FFFFFF;">
              Découvrir
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .practical-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }
  .practical-tile {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    padding: 30px;
    text-decoration: none;
    display: block;
    transition: transform 0.25s ease;
  }
  .practical-tile::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 0;
    border-style: solid;
    border-width: 0 0 42px 42px;
    border-color: transparent transparent rgba(0, 0, 0, 0.16) transparent;
  }
  .practical-tile:hover {
    transform: translateY(-4px);
  }
  .practical-icon {
    width: 50px;
    height: 50px;
    border-radius: 13px;
    background: rgba(255, 255, 255, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
</style>
