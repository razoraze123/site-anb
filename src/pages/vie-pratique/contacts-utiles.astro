---
import Layout from '../../layouts/Layout.astro';

const contacts = [
  {
    categorie: "Urgences",
    couleur: "#B14524",
    items: [
      { label: "SAMU (urgences médicales)", numero: "15" },
      { label: "Police secours", numero: "17" },
      { label: "Pompiers", numero: "18" },
      { label: "Numéro d'urgence européen", numero: "112" },
      { label: "SOS Médecins Bordeaux", numero: "05 56 79 22 22" },
    ]
  },
  {
    categorie: "Administration & Préfecture",
    couleur: "#176B4D",
    items: [
      { label: "Préfecture de la Gironde", numero: "05 56 90 60 60", lien: "https://www.gironde.gouv.fr" },
      { label: "CPAM Gironde (Sécu)", numero: "36 46", lien: "https://www.ameli.fr" },
      { label: "CAF Gironde (aides logement)", numero: "32 30", lien: "https://www.caf.fr" },
      { label: "France Travail Bordeaux", numero: "3949", lien: "https://www.francetravail.fr" },
    ]
  },
  {
    categorie: "Logement & Services",
    couleur: "#E97824",
    items: [
      { label: "CROUS Bordeaux-Aquitaine", numero: "05 56 33 92 00", lien: "https://www.crous-bordeaux.fr" },
      { label: "Adil 33 (conseil logement)", numero: "05 56 52 34 28", lien: "https://www.adil33.org" },
      { label: "CLCV Bordeaux (associations conso)", numero: "05 56 91 94 95" },
      { label: "Électricité / EDF dépannage", numero: "09 72 67 50 33" },
    ]
  },
  {
    categorie: "Transport",
    couleur: "#176B4D",
    items: [
      { label: "TBM (tramway/bus Bordeaux)", numero: "05 57 57 88 88", lien: "https://www.infotbm.com" },
      { label: "SNCF (trains régionaux)", numero: "36 35", lien: "https://www.sncf-connect.com" },
      { label: "Aéroport Bordeaux-Mérignac", numero: "05 56 34 50 50", lien: "https://www.bordeaux.aeroport.fr" },
    ]
  },
  {
    categorie: "Ambassade & Consulat",
    couleur: "#3d405b",
    items: [
      { label: "Ambassade du Niger à Paris", numero: "+33 1 45 04 80 60" },
      { label: "Consulat du Niger à Paris", numero: "+33 1 45 04 79 60" },
    ]
  },
];
---

<Layout title="Contacts utiles à Bordeaux" description="Numéros et adresses utiles pour toutes vos démarches à Bordeaux : urgences, administration, logement, transport.">
  <main style="background:var(--color-cream); min-height:88vh;">

    <div style="background:linear-gradient(135deg,#4a4e69 0%,#2b2d42 100%); padding:70px clamp(20px,5vw,80px) 80px;">
      <div style="max-width:860px;margin:0 auto;">
        <a href="/vie-pratique" style="display:inline-flex;align-items:center;gap:8px;color:rgba(255,255,255,0.7);font-size:13px;font-weight:600;text-decoration:none;margin-bottom:24px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          Vie pratique
        </a>
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
          <div style="width:54px;height:54px;border-radius:16px;background:rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6"><path d="M6 3a2 2 0 00-2 2c0 9 7 16 16 16a2 2 0 002-2v-2.5a1 1 0 00-.8-1L17 14.2a1 1 0 00-1 .25l-1.3 1.3a12 12 0 01-5.4-5.4l1.3-1.3a1 1 0 00.25-1L9.5 3.8a1 1 0 00-1-.8H6z"/></svg>
          </div>
          <span style="font-size:13px;font-weight:700;color:rgba(255,255,255,0.6);letter-spacing:0.08em;text-transform:uppercase;">Vie pratique</span>
        </div>
        <h1 style="font-family:var(--font-display);font-weight:800;font-size:clamp(2rem,4.5vw,3rem);color:#FFFFFF;margin:0 0 16px;line-height:1.15;">Contacts utiles à Bordeaux</h1>
        <p style="font-size:17px;line-height:1.7;color:rgba(255,255,255,0.8);margin:0;max-width:640px;">Tous les numéros et adresses essentiels pour vos démarches au quotidien à Bordeaux et en Gironde.</p>
      </div>
    </div>

    <div style="max-width:860px;margin:0 auto;padding:60px clamp(20px,4vw,40px) 80px;">
      <div style="display:grid;gap:28px;">
        {contacts.map(section => (
          <div style="background:#FFFFFF;border-radius:24px;overflow:hidden;box-shadow:0 8px 28px rgba(31,41,37,0.06);">
            <div style={`background:${section.couleur}; padding:16px 24px;`}>
              <h2 style="font-family:var(--font-display);font-size:16px;font-weight:800;color:#FFFFFF;margin:0;">{section.categorie}</h2>
            </div>
            <div style="padding:8px 0;">
              {section.items.map((item, i) => (
                <div style={`display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px 24px;${i < section.items.length - 1 ? 'border-bottom:1px solid rgba(31,41,37,0.05);' : ''}`}>
                  <div>
                    <div style="font-size:14.5px;font-weight:600;color:#1F2925;">{item.label}</div>
                    {item.lien && (
                      <a href={item.lien} target="_blank" rel="noopener" style="font-size:12px;color:var(--color-green);text-decoration:none;font-weight:600;">Site web →</a>
                    )}
                  </div>
                  <a href={`tel:${item.numero.replace(/\s/g,'')}`} style={`display:inline-flex;align-items:center;gap:6px;background:${section.couleur}18;color:${section.couleur};padding:8px 16px;border-radius:999px;font-size:14px;font-weight:800;text-decoration:none;white-space:nowrap;flex-shrink:0;transition:all 0.2s;`}>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 3a2 2 0 00-2 2c0 9 7 16 16 16a2 2 0 002-2v-2.5a1 1 0 00-.8-1L17 14.2a1 1 0 00-1 .25l-1.3 1.3a12 12 0 01-5.4-5.4l1.3-1.3a1 1 0 00.25-1L9.5 3.8a1 1 0 00-1-.8H6z"/></svg>
                    {item.numero}
                  </a>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div style="margin-top:48px;background:linear-gradient(135deg,rgba(23,107,77,0.08),rgba(233,120,36,0.06));border-radius:24px;padding:36px;text-align:center;border:1px solid rgba(23,107,77,0.1);">
        <p style="font-size:16px;font-weight:700;color:var(--color-dark);margin:0 0 8px;">Un contact manquant ou une information à corriger ?</p>
        <p style="font-size:14px;color:var(--color-muted-text);margin:0 0 20px;">Contactez-nous à <a href="mailto:contact@anb-bordeaux.fr" style="color:var(--color-green);font-weight:700;text-decoration:none;">contact@anb-bordeaux.fr</a></p>
        <a href="/adherer" style="display:inline-block;background:var(--color-orange);color:#FFFFFF;text-decoration:none;padding:13px 28px;border-radius:999px;font-weight:700;font-size:14.5px;box-shadow:0 8px 20px rgba(233,120,36,0.25);">Rejoindre la communauté ANB</a>
      </div>
    </div>
  </main>
</Layout>
