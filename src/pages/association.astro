---
import Layout from '../layouts/Layout.astro';
import { timeline, teamMembers } from '../lib/demo-data';
---

<Layout title="L'association" description="L'ANB est une association loi 1901 qui rassemble les Nigériens et les amis du Niger vivant à Bordeaux et dans sa métropole.">
  <main>
    <section style="max-width:1280px; margin:0 auto; padding:70px clamp(20px,4vw,48px) 20px;">
      <div style="font-size:13px; font-weight:700; color:#E97824; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;">L'association</div>
      <h1 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(2.1rem,4vw,3.2rem); color:#1F2925; margin:0 0 24px; max-width:760px; text-wrap:balance;">Une communauté née de la solidarité, portée par ses membres.</h1>
      <p style="font-size:18px; line-height:1.75; color:#3f4a45; max-width:680px; margin:0;">L'ANB est une association loi 1901 qui rassemble les Nigériens et les amis du Niger vivant à Bordeaux et dans sa métropole. Nous œuvrons pour l'accueil, l'entraide, la transmission culturelle et le lien entre nos membres.</p>
    </section>

    <section style="max-width:1280px; margin:0 auto; padding:60px clamp(20px,4vw,48px); display:flex; flex-wrap:wrap; gap:24px;">
      <div style="flex:1 1 220px; background:#FFFFFF; border-radius:22px; padding:30px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
        <h3 style="font-size:17px; font-weight:700; color:#176B4D; margin:0 0 10px;">Notre mission</h3>
        <p style="font-size:14.5px; line-height:1.6; color:#5a655f; margin:0;">Accueillir, accompagner et fédérer la communauté nigérienne de la métropole bordelaise.</p>
      </div>
      <div style="flex:1 1 220px; background:#FFFFFF; border-radius:22px; padding:30px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
        <h3 style="font-size:17px; font-weight:700; color:#176B4D; margin:0 0 10px;">Nos valeurs</h3>
        <p style="font-size:14.5px; line-height:1.6; color:#5a655f; margin:0;">Solidarité, transmission, respect et ouverture à toutes et tous.</p>
      </div>
      <div style="flex:1 1 220px; background:#FFFFFF; border-radius:22px; padding:30px; box-shadow:0 10px 26px rgba(31,41,37,0.06);">
        <h3 style="font-size:17px; font-weight:700; color:#176B4D; margin:0 0 10px;">Notre ambition</h3>
        <p style="font-size:14.5px; line-height:1.6; color:#5a655f; margin:0;">Faire de Bordeaux un lieu où nos racines nigériennes s'épanouissent.</p>
      </div>
    </section>

    <!-- MOT DU PRESIDENT -->
    <section style="background:#F0E9DA; padding:80px 0;">
      <div style="max-width:1280px; margin:0 auto; padding:0 clamp(20px,4vw,48px); display:flex; flex-wrap:wrap; gap:48px; align-items:center;">
        <div style="flex:0 1 260px; min-width:200px;">
          <div style="border-radius:24px; aspect-ratio:1/1; background:linear-gradient(160deg,#176B4D,#1F2925); box-shadow:0 20px 40px rgba(31,41,37,0.14);"></div>
        </div>
        <div style="flex:1 1 460px; min-width:280px;">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="#E97824"><path d="M7 8c-2.5 0-4 2-4 4.5S4.5 17 7 17c0-3 1.5-5 4-5.5V8H7zm10 0c-2.5 0-4 2-4 4.5s1.5 4.5 4 4.5c0-3 1.5-5 4-5.5V8h-4z"></path></svg>
          <p style="font-size:19px; line-height:1.7; color:#1F2925; font-style:italic; margin:18px 0 24px; max-width:600px;">« L'ANB est le fruit de l'engagement de celles et ceux qui ont voulu, un jour, que personne ne se sente seul à Bordeaux. Chaque événement, chaque geste d'entraide, fait grandir cette famille que nous construisons ensemble. »</p>
          <div style="font-weight:700; color:#1F2925; font-size:15px;">Prénom Nom</div>
          <div style="font-size:14px; color:#5a655f;">Président de l'ANB</div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section style="max-width:900px; margin:0 auto; padding:90px clamp(20px,4vw,48px);">
      <h2 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(1.7rem,2.8vw,2.2rem); color:#1F2925; margin:0 0 48px; text-align:center;">Notre parcours</h2>
      <div style="display:flex; flex-direction:column; gap:0;">
        {timeline.map((step) => (
          <div style="display:flex; gap:24px; padding-bottom:36px; position:relative;">
            <div style="display:flex; flex-direction:column; align-items:center; flex-shrink:0;">
              <div style="width:14px; height:14px; border-radius:50%; background:#E97824;"></div>
              <div style="width:2px; flex:1; background:rgba(31,41,37,0.12); margin-top:4px;"></div>
            </div>
            <div style="padding-bottom:6px;">
              <div style="font-size:13px; font-weight:700; color:#176B4D; margin-bottom:6px;">{step.year}</div>
              <div style="font-size:15.5px; line-height:1.6; color:#3f4a45;">{step.text}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- EQUIPE -->
    <section style="background:#FFFFFF; padding:90px 0;">
      <div style="max-width:1280px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
        <h2 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(1.7rem,2.8vw,2.2rem); color:#1F2925; margin:0 0 44px; text-align:center;">Le bureau de l'ANB</h2>
        <div data-grid-mobile="2" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:24px;">
          {teamMembers.map((member) => (
            <div style="text-align:center;">
              <div style={`border-radius:18px; aspect-ratio:1/1; background:${member.bg}; margin-bottom:14px;`}></div>
              <div style="font-weight:700; color:#1F2925; font-size:15px;">{member.name}</div>
              <div style="font-size:13px; color:#E97824; font-weight:600;">{member.role}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- POURQUOI REJOINDRE -->
    <section data-band style="background:#176B4D; padding:90px 0;">
      <div style="max-width:1280px; margin:0 auto; padding:0 clamp(20px,4vw,48px); text-align:center;">
        <h2 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(1.8rem,3vw,2.4rem); color:#FFFFFF; margin:0 0 40px;">Pourquoi rejoindre l'ANB ?</h2>
        <div data-grid-mobile="1" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:20px; margin-bottom:44px;">
          <div style="background:rgba(255,255,255,0.08); border-radius:20px; padding:26px; color:#FFFFFF;">Un réseau chaleureux dès votre arrivée</div>
          <div style="background:rgba(255,255,255,0.08); border-radius:20px; padding:26px; color:#FFFFFF;">Des événements toute l'année</div>
          <div style="background:rgba(255,255,255,0.08); border-radius:20px; padding:26px; color:#FFFFFF;">Un lien vivant avec vos racines</div>
        </div>
        <a href="/adherer" style="background:#E97824; color:#FFFFFF; border:none; padding:17px 34px; border-radius:999px; font-weight:700; font-size:15px; cursor:pointer; display:inline-block;">Adhérer à l'ANB</a>
      </div>
    </section>
  </main>
</Layout>
