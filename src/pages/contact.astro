---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Une question, une idée, besoin d'aide ? Contactez l'ANB Bordeaux.">
  <main>
    <section style="max-width:1280px; margin:0 auto; padding:70px clamp(20px,4vw,48px) 90px; display:flex; flex-wrap:wrap; gap:56px;">
      <div data-reveal style="flex:1 1 380px; min-width:280px;">
        <div style="font-size:13px; font-weight:700; color:#E97824; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;">Contact</div>
        <h1 style="font-family:'Unbounded',sans-serif; font-weight:700; font-size:clamp(2rem,3.6vw,2.8rem); color:#1F2925; margin:0 0 24px;">Parlons-nous.</h1>
        <p style="font-size:17px; line-height:1.7; color:#3f4a45; margin:0 0 40px;">Une question, une idée, besoin d'aide ? Notre équipe vous répond avec plaisir.</p>

        <div style="display:flex; flex-direction:column; gap:22px;">
          <div style="display:flex; gap:16px; align-items:center;">
            <div style="width:44px; height:44px; border-radius:12px; background:rgba(23,107,77,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.7"><path d="M4 4h16v16H4z" opacity="0"></path><path d="M3 6l9 6 9-6"></path><rect x="3" y="5" width="18" height="14" rx="2"></rect></svg>
            </div>
            <div>
              <div style="font-size:13px; color:#5a655f;">Email</div>
              <div style="font-size:15px; font-weight:700; color:#1F2925;">contact@anb-bordeaux.fr</div>
            </div>
          </div>
          <div style="display:flex; gap:16px; align-items:center;">
            <div style="width:44px; height:44px; border-radius:12px; background:rgba(233,120,36,0.12); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E97824" stroke-width="1.7"><path d="M6 3a2 2 0 00-2 2c0 9 7 16 16 16a2 2 0 002-2v-2.5a1 1 0 00-.8-1L17 14.2a1 1 0 00-1 .25l-1.3 1.3a12 12 0 01-5.4-5.4l1.3-1.3a1 1 0 00.25-1L9.5 3.8a1 1 0 00-1-.8H6z"></path></svg>
            </div>
            <div>
              <div style="font-size:13px; color:#5a655f;">Téléphone</div>
              <div style="font-size:15px; font-weight:700; color:#1F2925;">06 00 00 00 00</div>
            </div>
          </div>
          <div style="display:flex; gap:16px; align-items:center;">
            <div style="width:44px; height:44px; border-radius:12px; background:rgba(23,107,77,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#176B4D" stroke-width="1.7"><path d="M12 21s-7-4.35-7-10A5 5 0 0112 6a5 5 0 017 5c0 5.65-7 10-7 10z"></path><circle cx="12" cy="11" r="1.6"></circle></svg>
            </div>
            <div>
              <div style="font-size:13px; color:#5a655f;">Adresse</div>
              <div style="font-size:15px; font-weight:700; color:#1F2925;">Bordeaux Métropole</div>
            </div>
          </div>
        </div>

        <div style="border-radius:22px; aspect-ratio:16/9; background:linear-gradient(150deg,#E8D8BF,#176B4D); margin-top:36px;"></div>
      </div>

      <div data-reveal style="flex:1 1 420px; min-width:300px;">
        <div style="background:#FFFFFF; border-radius:28px; padding:clamp(28px,3vw,40px); box-shadow:0 20px 50px rgba(31,41,37,0.1);">
          <h3 style="font-size:19px; font-weight:700; color:#1F2925; margin:0 0 22px;">Envoyez-nous un message</h3>
          <form id="contact-form" style="display:flex; flex-direction:column; gap:16px;">
            <div>
              <label for="contact-nom" style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Nom complet</label>
              <input id="contact-nom" name="nom" required style="width:100%; padding:13px 16px; border-radius:12px; border:1.5px solid #d8d0c0; font-size:14.5px; font-family:inherit;" placeholder="Votre nom" />
            </div>
            <div>
              <label for="contact-email" style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Email</label>
              <input id="contact-email" name="email" type="email" required style="width:100%; padding:13px 16px; border-radius:12px; border:1.5px solid #d8d0c0; font-size:14.5px; font-family:inherit;" placeholder="vous@email.fr" />
            </div>
            <div>
              <label for="contact-sujet" style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Sujet</label>
              <input id="contact-sujet" name="sujet" style="width:100%; padding:13px 16px; border-radius:12px; border:1.5px solid #d8d0c0; font-size:14.5px; font-family:inherit;" placeholder="Objet de votre message" />
            </div>
            <div>
              <label for="contact-message" style="font-size:13px; font-weight:700; color:#1F2925; display:block; margin-bottom:6px;">Message</label>
              <textarea id="contact-message" name="message" rows="4" required style="width:100%; padding:13px 16px; border-radius:12px; border:1.5px solid #d8d0c0; font-size:14.5px; font-family:inherit; resize:vertical;" placeholder="Votre message"></textarea>
            </div>
            <button type="submit" style="background:#E97824; color:#FFFFFF; border:none; padding:16px; border-radius:999px; font-weight:700; font-size:15px; cursor:pointer; margin-top:8px; box-shadow:0 10px 22px rgba(233,120,36,0.28);">Envoyer le message</button>
            <p id="contact-form-note" style="display:none; font-size:13.5px; color:#5a655f; text-align:center; margin:4px 0 0;">Ce formulaire sera bientôt connecté (validation et envoi sécurisés en préparation) — merci de nous écrire directement à contact@anb-bordeaux.fr en attendant.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <script>
    const form = document.querySelector<HTMLFormElement>('#contact-form');
    const note = document.querySelector<HTMLElement>('#contact-form-note');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      if (note) note.style.display = 'block';
    });
  </script>
</Layout>
